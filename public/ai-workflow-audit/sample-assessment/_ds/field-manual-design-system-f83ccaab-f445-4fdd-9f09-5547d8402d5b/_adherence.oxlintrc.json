{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Archivo|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Archivo, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bridge'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|headline|body|ctaLabel|subline|onCtaClick|key|ref|className|style|children)$/]",
        "message": "<Bridge> doesn't accept that prop. Declared props: eyebrow, headline, body, ctaLabel, subline, onCtaClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|onClick|disabled|showArrow|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, onClick, disabled, showArrow, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|paper)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|stat|attribution|className|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: label, stat, attribution, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|painLine|dispositions|frequency|automationLevel|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: id, name, painLine, dispositions, frequency, automationLevel, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorStripDisposition'] > JSXAttribute > JSXIdentifier[name!=/^(?:disposition|weight|key|ref|className|style|children)$/]",
        "message": "<ColorStripDisposition> doesn't accept that prop. Declared props: disposition, weight."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorStripDisposition'] > JSXAttribute[name.name='disposition'] > Literal[value!=/^(?:eliminate|simplify|automate|optimize|report)$/]",
        "message": "<ColorStripDisposition> disposition must be one of 'eliminate' | 'simplify' | 'automate' | 'optimize' | 'report'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DispositionTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:disposition|size|className|key|ref|className|style|children)$/]",
        "message": "<DispositionTag> doesn't accept that prop. Declared props: disposition, size, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='DispositionTag'] > JSXAttribute[name.name='disposition'] > Literal[value!=/^(?:eliminate|simplify|automate|optimize|report)$/]",
        "message": "<DispositionTag> disposition must be one of 'eliminate' | 'simplify' | 'automate' | 'optimize' | 'report'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DispositionTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:full|small)$/]",
        "message": "<DispositionTag> size must be one of 'full' | 'small'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:stat|unit|description|attribution|qualitative|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: stat, unit, description, attribution, qualitative."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Bridge": {
        "replaces": []
      },
      "Button": {
        "replaces": []
      },
      "Callout": {
        "replaces": []
