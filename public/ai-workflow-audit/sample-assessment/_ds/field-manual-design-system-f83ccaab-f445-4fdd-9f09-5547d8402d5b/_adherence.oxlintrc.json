      "--ucl-gutter",
      "--ucl-header-h",
      "--ucl-ink",
      "--ucl-ink-2",
      "--ucl-ink-3",
      "--ucl-line",
      "--ucl-line-2",
      "--ucl-max-width",
      "--ucl-mono",
      "--ucl-optimize",
      "--ucl-optimize-bg",
      "--ucl-optimize-ln",
      "--ucl-paper",
      "--ucl-paper-card",
      "--ucl-r-lg",
      "--ucl-r-md",
      "--ucl-r-sm",
      "--ucl-r-xl",
      "--ucl-r-xs",
      "--ucl-report",
      "--ucl-report-bg",
      "--ucl-report-ln",
      "--ucl-sans",
      "--ucl-serif",
      "--ucl-simplify",
      "--ucl-simplify-bg",
      "--ucl-simplify-ln",
      "--ucl-sp-1",
      "--ucl-sp-10",
      "--ucl-sp-12",
      "--ucl-sp-16",
      "--ucl-sp-2",
      "--ucl-sp-3",
      "--ucl-sp-4",
      "--ucl-sp-5",
      "--ucl-sp-6",
      "--ucl-sp-8"
    ],
    "tokenKinds": {
      "--ucl-paper": "color",
      "--ucl-paper-card": "color",
      "--ucl-ink": "color",
