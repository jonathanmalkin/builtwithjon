      "--ucl-simplify-ln": "color",
      "--ucl-automate": "color",
      "--ucl-automate-bg": "color",
      "--ucl-automate-ln": "color",
      "--ucl-optimize": "color",
      "--ucl-optimize-bg": "color",
      "--ucl-optimize-ln": "color",
      "--ucl-report": "color",
      "--ucl-report-bg": "color",
      "--ucl-report-ln": "color",
      "--ucl-serif": "font",
      "--ucl-sans": "font",
      "--ucl-mono": "font",
      "--ucl-r-xs": "spacing",
      "--ucl-r-sm": "spacing",
      "--ucl-r-md": "spacing",
      "--ucl-r-lg": "spacing",
      "--ucl-r-xl": "spacing",
      "--ucl-max-width": "spacing",
      "--ucl-gutter": "spacing",
