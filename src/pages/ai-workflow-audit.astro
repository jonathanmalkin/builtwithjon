---
import Base from '../layouts/Base.astro';

const formEndpoint = 'https://formspree.io/f/xdapgpae';
const thanksUrl = '/ai-workflow-audit/thanks';
---

<Base
  title="AI Workflow Audit"
  description="Map one recurring workflow, find where AI can safely help, and leave with a practical first step."
>
  <section class="audit-page">
    <div class="audit-hero">
      <p class="audit-label">AI Workflow Audit</p>
      <h1>Find the first workflow AI should actually help with.</h1>
      <p class="audit-lede">
        Bring one recurring process that is costing time, follow-up, or trust.
        I map the workflow, identify safe AI assists, and tell you whether to
        pilot now, clean up first, hand it off, or leave it alone.
      </p>
    </div>

    <div class="audit-grid">
      <div class="audit-copy">
        <h2>Not a strategy deck.</h2>
        <p>
          This starts with the work you already do: email, client follow-up,
          proposals, scheduling, finance/admin reporting, content operations,
          or project handoffs.
        </p>
        <ul>
          <li>One current workflow map</li>
          <li>Top friction points and risks</li>
          <li>One safe first pilot recommendation</li>
          <li>A clear "not yet" when AI is the wrong move</li>
        </ul>
      </div>

      <form
        id="ai-audit-form"
        action={formEndpoint}
        method="POST"
        class="audit-form panel"
        data-thanks={thanksUrl}
      >
        <input type="hidden" name="_subject" value="AI Workflow Audit lead" />
        <input type="hidden" name="inquiry_type" value="ai-workflow-audit-lead" />

        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required class="form-input" autocomplete="name" />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required class="form-input" autocomplete="email" inputmode="email" spellcheck="false" />
        </div>

        <div class="form-group">
          <label for="company">Company or practice</label>
          <input type="text" id="company" name="company" class="form-input" autocomplete="organization" />
        </div>

        <div class="form-group">
          <label for="workflow">What recurring workflow should we inspect first?</label>
          <textarea
            id="workflow"
            name="workflow"
            rows="4"
            required
            class="form-input"
            placeholder="Example: lead follow-up, proposal drafts, customer emails, weekly reporting..."
          ></textarea>
        </div>

        <div class="form-group">
          <label for="business_consequence">What does it affect most?</label>
          <select id="business_consequence" name="business_consequence" class="form-input">
            <option value="">Choose one</option>
            <option value="Owner time">Owner time</option>
            <option value="Revenue or follow-up">Revenue or follow-up</option>
            <option value="Customer experience">Customer experience</option>
            <option value="Cash or admin">Cash or admin</option>
            <option value="Team clarity">Team clarity</option>
            <option value="Not sure yet">Not sure yet</option>
          </select>
        </div>

        <div class="form-group">
          <label for="tools">Which tools or systems are involved?</label>
          <input
            type="text"
            id="tools"
            name="tools"
            class="form-input"
            placeholder="Email, calendar, CRM, QuickBooks, forms, spreadsheets..."
          />
        </div>

        <div class="form-group">
          <label for="urgency">How soon do you want to improve it?</label>
          <select id="urgency" name="urgency" class="form-input">
            <option value="">Choose one</option>
            <option value="This month">This month</option>
            <option value="This quarter">This quarter</option>
            <option value="Just exploring">Just exploring</option>
          </select>
        </div>

        <button type="submit" class="form-submit audit-submit">Send workflow</button>
        <p class="audit-note">Takes about 90 seconds. I reply personally if there is a workflow worth mapping.</p>
        <p class="audit-error" hidden role="alert" aria-live="polite">
          Something went wrong. Email <a href="mailto:jonathan@builtwithjon.com">jonathan@builtwithjon.com</a> and I will help.
        </p>
      </form>
    </div>
  </section>

  <script is:inline define:vars={{ thanksUrl }}>
    const form = document.getElementById('ai-audit-form');
    if (form) {
      const submitBtn = form.querySelector('.audit-submit');
      const errorEl = form.querySelector('.audit-error');

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (errorEl) errorEl.hidden = true;
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';
        }
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (response.ok) {
            window.location.assign(thanksUrl);
            return;
          }
          throw new Error('Submission failed');
        } catch (err) {
          if (errorEl) errorEl.hidden = false;
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send workflow';
          }
        }
      });
    }
  </script>

  <style>
    .audit-page {
      margin: 0 auto 4rem;
      max-width: var(--max-width-wide);
    }

    .audit-hero {
      padding: 1.5rem 0 2.25rem;
      max-width: 820px;
    }

    .audit-label {
      color: var(--color-copper);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      line-height: 1.2;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .audit-hero h1 {
      font-size: clamp(2rem, 5vw, 3.35rem);
      letter-spacing: 0;
      line-height: 1.06;
      margin: 0 0 1rem;
      max-width: 760px;
    }

    .audit-lede {
      color: var(--color-text-muted);
      font-size: 1.08rem;
      max-width: 700px;
    }

    .audit-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1fr);
      gap: 1.5rem;
      align-items: start;
      min-width: 0;
    }

    .audit-copy {
      border-top: 1px solid var(--color-border);
      min-width: 0;
      padding-top: 1.25rem;
    }

    .audit-copy h2 {
      margin-top: 0;
    }

    .audit-copy ul {
      color: var(--color-text-muted);
    }

    .audit-form {
      border-radius: 12px;
      min-width: 0;
      padding: 1.25rem;
    }

    .audit-form .form-group {
      margin-bottom: 0.95rem;
    }

    .audit-form label {
      color: var(--color-text);
      display: block;
      font-size: 0.84rem;
      font-weight: 750;
      margin-bottom: 0.35rem;
    }

    .audit-form .form-input {
      background: #fff;
      border: 1px solid var(--color-border);
      border-radius: 6px;
      color: var(--color-text);
      font: inherit;
      min-height: 44px;
      padding: 0.65rem 0.75rem;
      width: 100%;
    }

    .audit-form textarea.form-input {
      min-height: 118px;
      resize: vertical;
    }

    .audit-submit {
      background: var(--color-blue-mug);
      border: 0;
      border-radius: 6px;
      color: #fff;
      cursor: pointer;
      font: inherit;
      font-weight: 800;
      padding: 0.75rem 1rem;
      width: 100%;
    }

    .audit-submit:hover {
      background: var(--color-blueprint);
    }

    .audit-submit:disabled {
      cursor: wait;
      opacity: 0.75;
    }

    .audit-note,
    .audit-error {
      color: var(--color-text-muted);
      font-size: 0.84rem;
      margin: 0.8rem 0 0;
    }

    @media (max-width: 760px) {
      .audit-grid {
        grid-template-columns: 1fr;
      }

      .audit-page,
      .audit-hero,
      .audit-grid,
      .audit-copy,
      .audit-form {
        max-width: 100%;
      }

      .audit-hero h1 {
        font-size: clamp(1.85rem, 8vw, 2.35rem);
        line-height: 1.12;
        overflow-wrap: anywhere;
      }

      .audit-lede,
      .audit-copy p,
      .audit-copy li,
      .audit-form label,
      .audit-note,
      .audit-error {
        overflow-wrap: anywhere;
      }

      .audit-form {
        border-radius: 8px;
        padding: 1rem;
      }

      .audit-form .form-input {
        max-width: 100%;
        min-width: 0;
      }
    }
  </style>
</Base>
