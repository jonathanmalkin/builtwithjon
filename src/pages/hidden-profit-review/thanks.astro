---
import Base from '../../layouts/Base.astro';

const bookingUrl = 'https://calendar.app.google/rC9Kz37aZANXAUgt5';
---

<Base
  title="The Hidden Profit Review: next step"
  description="Thanks for starting The Hidden Profit Review. Book a quick call and I will come prepared."
>
  <div class="container next-page">
    <div class="book-hero panel">
      <p class="book-kicker">You're in</p>
      <h1>Let's find the hidden profit.</h1>
      <p class="book-sub">
        I have your details. Book a quick call below and I will follow up by
        email to learn about the workflow before we talk.
      </p>

      <div class="book-cta-wrap">
        <a href={bookingUrl} class="book-cta" target="_blank" rel="noopener">
          <span class="book-cta-main">Book a quick call &rarr;</span>
          <span class="book-cta-sub">Free &middot; 15 min</span>
        </a>
      </div>

      <ul class="book-benefits">
        <li>Bring one real workflow, not a whole-company wish list</li>
        <li>We will decide if AI, cleanup, or no action is the honest next step</li>
        <li>No obligation and no tool pitch</li>
      </ul>
    </div>
  </div>
</Base>
