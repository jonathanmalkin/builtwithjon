---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact"
  description="Contact Jonathan Malkin about a workflow leak, the Hidden Profit Review waitlist, AI workshops, or implementation work."
>
  <div class="container contact-layout">
    <div class="contact-intro panel">
      <p class="eyebrow">Contact</p>
      <h1>Tell me what you are trying to fix.</h1>

      <p class="contact-lede">
        Start with the scorecard if you are still finding the leak. Join the
        waitlist if you already know the workflow needs a closer look. Use the
        form for workshops, partnerships, or a direct note.
      </p>

      <div class="contact-routes" aria-label="Best next steps">
        <a href="/scorecard/" class="contact-route contact-route-primary" data-track="cta:scorecard-contact">
          <span class="contact-route-label">Not sure where the leak is?</span>
          <span class="contact-route-title">Take the 3-minute scorecard</span>
          <span class="contact-route-copy">Free, no call, no pitch. It points at the likely deals, time, or cash leak.</span>
        </a>
        <a href="/hidden-profit-review/#waitlist" class="contact-route" data-track="cta:waitlist-contact">
          <span class="contact-route-label">Want me on it personally?</span>
          <span class="contact-route-title">Join the review waitlist</span>
          <span class="contact-route-copy">I read entries within two business days and send invites in order.</span>
        </a>
      </div>

      <div class="contact-notes">
        <div>
          <strong>Prefer email?</strong>
          <p><a href="mailto:jonathan@builtwithjon.com">jonathan@builtwithjon.com</a></p>
        </div>
      </div>
    </div>

    <form
      action="https://formspree.io/f/xdapgpae"
      method="POST"
      class="contact-form"
      data-track-form="contact"
    >
      <input type="hidden" name="_subject" value="Contact inquiry from builtwithjon.com" />
      <input type="hidden" name="inquiry_type" value="contact" />
      <div class="contact-form-head">
        <p class="eyebrow">Send a note</p>
        <h2>For anything that needs context.</h2>
      </div>
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required class="form-input" />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required class="form-input" />
      </div>
      <div class="form-group">
        <label for="message">What should I know?</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          class="form-input"
          placeholder="What kind of business or team is this? What workflow is creating drag? What tools are involved? What would a useful next step look like?"
        ></textarea>
      </div>
      <button type="submit" class="form-submit">Send</button>
    </form>
  </div>

  <style>
    .contact-layout {
      align-items: start;
      grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.8fr);
      max-width: 1120px;
    }

    .contact-intro,
    .contact-form {
      padding: clamp(1.25rem, 2vw, 1.75rem);
    }

    .contact-intro h1 {
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      letter-spacing: -0.02em;
      line-height: 1.04;
      margin: 0.55rem 0 0.85rem;
      max-width: 11ch;
    }

    .contact-lede {
      color: var(--color-text-muted);
      font-size: 1rem;
      line-height: 1.55;
    }

    .contact-routes {
      display: grid;
      gap: 0.75rem;
      margin: 1.1rem 0 0;
    }

    .contact-route {
      border: 1px solid var(--color-border);
      border-radius: 8px;
      color: var(--color-text);
      display: grid;
      gap: 0.2rem;
      padding: 0.85rem 0.95rem;
      text-decoration: none;
      transition: background 0.15s ease, border-color 0.15s ease;
    }

    .contact-route:hover {
      background: rgba(59, 110, 143, 0.08);
      border-color: var(--color-blue-mug);
      color: var(--color-text);
      text-decoration: none;
    }

    .contact-route-primary {
      background: var(--color-blue-mug);
      border-color: var(--color-blue-mug);
      color: #fff;
    }

    .contact-route-primary:hover {
      background: var(--color-blueprint);
      color: #fff;
    }

    .contact-route-label {
      color: currentColor;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      opacity: 0.76;
      text-transform: uppercase;
    }

    .contact-route-title {
      font-family: var(--font-body);
      font-weight: 850;
    }

    .contact-route-copy {
      color: currentColor;
      font-size: 0.86rem;
      line-height: 1.45;
      opacity: 0.82;
    }

    .contact-form-head {
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 1.2rem;
      padding-bottom: 1rem;
    }

    .contact-form-head h2 {
      font-size: clamp(1.35rem, 2.2vw, 1.8rem);
      letter-spacing: -0.015em;
      margin: 0.35rem 0 0;
    }

    .contact-form .form-input {
      background: #fff;
      min-height: 44px;
    }

    .contact-form textarea.form-input {
      min-height: 150px;
    }

    @media (max-width: 760px) {
      .contact-layout {
        grid-template-columns: 1fr;
        max-width: 100%;
      }

      .contact-intro h1 {
        max-width: 12ch;
      }
    }
  </style>
</Base>
