---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Waitlist Request Received"
  description="Your Build Your Practical AI Assistant waitlist request was received."
>
  <section class="container assistant-thanks panel">
    <p class="eyebrow">Waitlist request received</p>
    <h1>I got it.</h1>
    <p>
      I will review what you sent and follow up personally when the next small
      cohort is forming. If it looks like a fit, I will confirm timing and send
      payment details before your seat is held.
    </p>
    <p>
      There is no payment due from joining the waitlist. Cohorts are kept small
      so setup help and screen-share verification stay practical.
    </p>
    <p><a href="/ai-assistant-workshop/">Back to the workshop page</a></p>
  </section>
</Base>

<style>
  .assistant-thanks {
    padding: 1.5rem;
  }

  .assistant-thanks h1 {
    margin-top: 0.35rem;
    letter-spacing: 0;
  }
</style>
