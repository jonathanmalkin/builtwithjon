---
import Base from '../../layouts/Base.astro';

const description =
  'A guided, no-install path for small-business owners: find the leak in deals, time, or cash, price it, and see what to fix first.';

const guidedPrompt = `Visit https://builtwithjon.com/tools/. Start with the Hidden Profit Scorecard unless I already know the leak. Ask me one question at a time, run the scorecard using the site's public tools, and explain the result in plain language. Then help me choose and run the matching leak calculator with my real numbers. Finish by showing me one relevant use case and the next practical step. Do not ask for sensitive personal information.`;
const claudeUrl = `claude://claude.ai/new?q=${encodeURIComponent(guidedPrompt)}`;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'Tools for finding hidden profit',
      description,
      url: 'https://builtwithjon.com/tools/',
      isPartOf: { '@type': 'WebSite', name: 'Built with Jon', url: 'https://builtwithjon.com/' },
    },
    {
      '@type': 'HowTo',
      name: 'Find and price an operational profit leak',
      description: 'Use the scorecard, calculator, and use-case library in sequence.',
      totalTime: 'PT10M',
      step: [
        { '@type': 'HowToStep', position: 1, name: 'Find the leak', text: 'Run the Hidden Profit Scorecard to compare deals, time, and cash.', url: 'https://builtwithjon.com/scorecard/' },
        { '@type': 'HowToStep', position: 2, name: 'Price the leak', text: 'Use the matching calculator with real business inputs.', url: 'https://builtwithjon.com/tools/leak-calculator/' },
        { '@type': 'HowToStep', position: 3, name: 'See the fix', text: 'Open a relevant worked use case and choose one practical next move.', url: 'https://builtwithjon.com/use-cases/' },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://builtwithjon.com/' },
        { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://builtwithjon.com/tools/' },
      ],
    },
  ],
};

const steps = [
  {
    number: '1',
    label: 'Diagnose',
    title: 'Find the leak',
    body: 'Answer nine short questions. The scorecard compares deals, time, and cash and names the one worth investigating first.',
    detail: 'Start here when you are not sure what is costing you most.',
    href: '/scorecard/',
    action: 'Take the scorecard',
    event: 'tools:start:scorecard',
  },
  {
    number: '2',
    label: 'Estimate',
    title: 'Put a number on it',
    body: 'Choose the calculator that matches the result, then replace the example inputs with numbers from your own business.',
    detail: 'Ten calculators cover missed calls, slow replies, bids, no-shows, invoices, and more.',
    href: '/tools/leak-calculator/',
    action: 'Choose a calculator',
    event: 'tools:start:calculator',
  },
  {
    number: '3',
    label: 'Decide',
    title: 'See what a fix looks like',
    body: 'Open a similar workflow, see where AI fits and where it does not, then choose one small move instead of a transformation project.',
    detail: '96 worked examples across 15 business and industry categories.',
    href: '/use-cases/',
    action: 'Find a similar use case',
    event: 'tools:start:use-cases',
  },
];
---

<Base title="Tools for finding hidden profit" description={description} schema={schema}>
  <main class="tools-page">
    <section class="tools-hero" aria-labelledby="tools-title">
      <div class="tools-hero-copy">
        <p class="tools-kicker">A ten-minute working session</p>
        <h1 id="tools-title">Find the leak. Price it. Fix the right thing.</h1>
        <p class="tools-lede">
          These free tools turn a vague operational headache into a practical next move.
          Start with the scorecard, follow the result to the right calculator, then see how a similar workflow can improve.
        </p>
        <div class="tools-hero-actions">
          <a class="tools-button tools-button-primary" href="/scorecard/" data-track="tools:start:scorecard">
            Start the guided path <span aria-hidden="true">→</span>
          </a>
          <a class="tools-text-link" href="#use-with-ai">Use it with your AI</a>
        </div>
      </div>

      <aside class="tools-route" aria-label="The recommended path">
        <p class="tools-route-title">The recommended path</p>
        <ol>
          <li><span>1</span><strong>Score</strong><small>Deals · time · cash</small></li>
          <li><span>2</span><strong>Calculate</strong><small>Monthly · annual</small></li>
          <li><span>3</span><strong>Choose</strong><small>One useful move</small></li>
        </ol>
        <p class="tools-route-note">Already know the exact leak? You can <a href="/tools/leak-calculator/">go straight to a calculator</a>.</p>
      </aside>
    </section>

    <section class="tools-sequence" aria-labelledby="sequence-title">
      <header class="tools-section-head">
        <h2 id="sequence-title">One path, three decisions.</h2>
        <p>Each step makes the next one narrower. You do not need to understand AI or install anything.</p>
      </header>

      <ol class="tools-steps">
        {steps.map((step) => (
          <li class="tools-step">
            <div class="tools-step-number" aria-hidden="true">{step.number}</div>
            <div class="tools-step-copy">
              <p class="tools-step-label">{step.label}</p>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
              <small>{step.detail}</small>
            </div>
            <a class="tools-step-link" href={step.href} data-track={step.event}>
              {step.action} <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="tools-ai" id="use-with-ai" aria-labelledby="ai-title">
      <div class="tools-ai-intro">
        <div class="tools-ai-proof" aria-label="Tested with AI assistants">
          <span>Tested with Claude</span>
          <span>Tested with ChatGPT</span>
        </div>
        <h2 id="ai-title">Let your AI run the session with you.</h2>
        <p>
          Send it this page and the prompt below. A browser-capable assistant can ask the questions,
          use the public tools, explain the result, and guide you into the appropriate calculator.
        </p>
        <p class="tools-ai-boundary">No account or MCP setup is required. The tools are read-only, and scorecard answers and calculator inputs are not stored by the MCP server.</p>
      </div>

      <div class="tools-prompt-box">
        <p class="tools-prompt-label">Guided-session prompt</p>
        <p class="tools-prompt-text" id="tools-prompt-text">{guidedPrompt}</p>
        <div class="tools-prompt-actions">
          <button type="button" class="tools-copy" data-copy-prompt aria-describedby="copy-status">
            Copy for ChatGPT
          </button>
          <a class="tools-open-claude" href={claudeUrl} data-track="tools:open:claude">Open in Claude <span aria-hidden="true">↗</span></a>
        </div>
        <p class="tools-copy-status" id="copy-status" role="status" aria-live="polite"></p>
      </div>
    </section>

    <section class="tools-more" aria-labelledby="more-title">
      <div>
        <h2 id="more-title">Go deeper when the first answer is not enough.</h2>
        <p>The diagnostic path is the front door. These resources help with the decision that follows.</p>
      </div>
      <nav class="tools-more-links" aria-label="More Built with Jon resources">
        <a href="/dispositions/">
          <strong>Decision frameworks</strong>
          <span>Decide whether to eliminate, simplify, automate, optimize, or report.</span>
        </a>
        <a href="/articles/">
          <strong>Field notes</strong>
          <span>Read the evidence and implementation lessons behind the tools.</span>
        </a>
        <a href="/hidden-profit-review/#waitlist" data-track="tools:hpr-click">
          <strong>Hidden Profit Review</strong>
          <span>Have Jonathan measure one recurring workflow with your real data.</span>
        </a>
      </nav>
    </section>

    <p class="tools-footnote">
      Prefer a configured connection? The optional <a href="/mcp/">public MCP server</a> gives compatible clients direct access to the same read-only tools.
    </p>
  </main>

  <script is:inline>
    if (window.bwjTrack) window.bwjTrack('tools:view');

    const copyButton = document.querySelector('[data-copy-prompt]');
    const promptText = document.getElementById('tools-prompt-text');
    const copyStatus = document.getElementById('copy-status');

    copyButton?.addEventListener('click', async () => {
      const text = promptText?.textContent?.trim();
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        if (copyStatus) copyStatus.textContent = 'Copied. Paste it into Claude or ChatGPT.';
      } catch {
        const selection = window.getSelection();
        const range = document.createRange();
        if (promptText && selection) {
          selection.removeAllRanges();
          range.selectNodeContents(promptText);
          selection.addRange(range);
          if (copyStatus) copyStatus.textContent = 'The prompt is selected. Copy it, then paste it into your assistant.';
        }
      }
      if (window.bwjTrack) window.bwjTrack('tools:copy:chatgpt');
    });
  </script>

  <style is:global>
    .tools-page {
      --tools-ink: #1f1713;
      --tools-muted: #5e5047;
      --tools-paper: #fffdf8;
      --tools-line: #d8c8b2;
      --tools-blue: #315f7c;
      margin: 0 auto 4rem;
      max-width: var(--max-width-wide);
    }

    .tools-hero {
      display: grid;
      gap: 2rem;
      padding: 1rem 0 clamp(3rem, 8vw, 5.5rem);
    }

    .tools-kicker,
    .tools-route-title,
    .tools-step-label,
    .tools-prompt-label {
      color: var(--color-copper);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      line-height: 1.25;
      margin: 0;
      text-transform: uppercase;
    }

    .tools-hero h1 {
      font-size: clamp(2.55rem, 8vw, 5.25rem);
      letter-spacing: -0.04em;
      line-height: 0.94;
      margin: 0.75rem 0 1.2rem;
      max-width: 11ch;
      text-wrap: balance;
    }

    .tools-lede {
      color: var(--tools-muted);
      font-size: clamp(1rem, 2.6vw, 1.2rem);
      line-height: 1.6;
      max-width: 41rem;
      text-wrap: pretty;
    }

    .tools-hero-actions,
    .tools-prompt-actions {
      align-items: center;
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem 1.1rem;
      margin-top: 1.5rem;
    }

    .tools-button,
    .tools-copy,
    .tools-open-claude {
      align-items: center;
      border-radius: 5px;
      display: inline-flex;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 750;
      gap: 0.6rem;
      justify-content: center;
      padding: 0.82rem 1rem;
      text-decoration: none;
    }

    .tools-button-primary,
    .tools-copy {
      background: var(--tools-ink);
      border: 1px solid var(--tools-ink);
      color: var(--tools-paper);
    }

    .tools-button-primary:hover,
    .tools-copy:hover { background: #000; color: #fff; text-decoration: none; }
    .tools-text-link { color: var(--tools-ink); font-family: var(--font-mono); font-size: 0.73rem; text-decoration: underline; text-underline-offset: 0.2em; }

    .tools-route {
      align-self: end;
      background: var(--tools-blue);
      color: #fff;
      padding: 1.4rem;
    }

    .tools-route-title { color: #fff; opacity: 0.82; }
    .tools-route ol { list-style: none; margin: 1.2rem 0 1.3rem; padding: 0; }
    .tools-route li { align-items: center; border-bottom: 1px solid rgba(255,255,255,0.25); display: grid; gap: 0 0.8rem; grid-template-columns: 2rem 1fr; padding: 0.7rem 0; }
    .tools-route li > span { align-items: center; border: 1px solid rgba(255,255,255,0.55); border-radius: 50%; display: inline-flex; font-family: var(--font-mono); font-size: 0.65rem; height: 1.55rem; justify-content: center; width: 1.55rem; }
    .tools-route strong { font-size: 0.9rem; }
    .tools-route small { color: rgba(255,255,255,0.78); font-size: 0.7rem; grid-column: 2; }
    .tools-route-note { color: rgba(255,255,255,0.85); font-size: 0.76rem; line-height: 1.5; margin: 0; }
    .tools-route a { color: #fff; text-decoration: underline; text-underline-offset: 0.18em; }

    .tools-sequence { border-top: 1px solid var(--tools-line); padding: clamp(2.5rem, 7vw, 4.5rem) 0; }
    .tools-section-head { display: grid; gap: 0.8rem; margin-bottom: 2rem; }
    .tools-section-head h2,
    .tools-ai h2,
    .tools-more h2 { font-family: Newsreader, Georgia, serif; font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 500; letter-spacing: -0.035em; line-height: 1.02; margin: 0; text-wrap: balance; }
    .tools-section-head p { color: var(--tools-muted); line-height: 1.55; margin: 0; max-width: 35rem; }

    .tools-steps { border-top: 2px solid var(--tools-ink); list-style: none; margin: 0; padding: 0; }
    .tools-step { align-items: start; border-bottom: 1px solid var(--tools-line); display: grid; gap: 1rem; margin: 0; padding: 1.5rem 0; }
    .tools-step-number { color: var(--tools-blue); font-family: Newsreader, Georgia, serif; font-size: 2.6rem; line-height: 0.9; }
    .tools-step-copy h3 { font-size: clamp(1.35rem, 3vw, 1.8rem); margin: 0.3rem 0 0.55rem; }
    .tools-step-copy > p:not(.tools-step-label) { color: var(--tools-muted); font-size: 0.9rem; line-height: 1.55; margin: 0 0 0.5rem; max-width: 36rem; }
    .tools-step-copy small { color: var(--tools-muted); display: block; font-size: 0.72rem; line-height: 1.45; }
    .tools-step-link { align-self: center; color: var(--tools-ink); font-family: var(--font-mono); font-size: 0.72rem; font-weight: 750; text-decoration: underline; text-underline-offset: 0.22em; }

    .tools-ai { background: #f2e7d6; display: grid; gap: 1.8rem; margin: 1rem 0 clamp(3.5rem, 8vw, 5.5rem); padding: clamp(1.4rem, 4vw, 2.5rem); }
    .tools-ai-proof { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-bottom: 1.15rem; }
    .tools-ai-proof span { background: var(--tools-paper); border: 1px solid var(--tools-line); border-radius: 3px; color: var(--tools-muted); font-family: var(--font-mono); font-size: 0.61rem; font-weight: 750; padding: 0.35rem 0.48rem; text-transform: uppercase; }
    .tools-ai-intro > p { color: var(--tools-muted); font-size: 0.88rem; line-height: 1.55; margin: 1rem 0 0; max-width: 38rem; }
    .tools-ai-intro .tools-ai-boundary { font-size: 0.72rem; }
    .tools-prompt-box { background: var(--tools-paper); border: 2px solid var(--tools-ink); padding: clamp(1rem, 3vw, 1.5rem); }
    .tools-prompt-text { font-family: Newsreader, Georgia, serif; font-size: clamp(1.15rem, 3vw, 1.5rem); line-height: 1.3; margin: 0.75rem 0 0; }
    .tools-copy { cursor: pointer; }
    .tools-open-claude { border: 1px solid var(--tools-ink); color: var(--tools-ink); }
    .tools-open-claude:hover { background: #f7efe2; color: #000; text-decoration: none; }
    .tools-copy-status { color: var(--tools-muted); font-size: 0.7rem; margin: 0.7rem 0 0; min-height: 1.1em; }

    .tools-more { border-top: 2px solid var(--tools-ink); display: grid; gap: 2rem; padding-top: 2rem; }
    .tools-more > div > p { color: var(--tools-muted); font-size: 0.85rem; line-height: 1.5; margin: 0.8rem 0 0; }
    .tools-more-links { display: flex; flex-direction: column; }
    .tools-more-links a { border-top: 1px solid var(--tools-line); color: var(--tools-ink); display: grid; gap: 0.25rem; padding: 1rem 0; text-decoration: none; }
    .tools-more-links a:last-child { border-bottom: 1px solid var(--tools-line); }
    .tools-more-links a:hover strong { color: var(--tools-blue); text-decoration: underline; text-underline-offset: 0.2em; }
    .tools-more-links strong { font-size: 0.9rem; }
    .tools-more-links span { color: var(--tools-muted); font-size: 0.75rem; line-height: 1.45; }
    .tools-footnote { color: var(--tools-muted); font-size: 0.72rem; line-height: 1.5; margin: 2rem auto 0; max-width: 42rem; text-align: center; }
    .tools-footnote a { color: var(--tools-ink); text-decoration: underline; text-underline-offset: 0.18em; }

    @media (min-width: 680px) {
      .tools-hero { grid-template-columns: minmax(0, 1.4fr) minmax(250px, 0.6fr); padding-top: 1.5rem; }
      .tools-section-head { align-items: end; grid-template-columns: minmax(0, 1fr) minmax(260px, 0.7fr); }
      .tools-step { grid-template-columns: 3rem minmax(0, 1fr) minmax(150px, 0.35fr); }
      .tools-ai { grid-template-columns: minmax(0, 0.85fr) minmax(330px, 1.15fr); }
      .tools-more { grid-template-columns: minmax(0, 0.8fr) minmax(350px, 1.2fr); }
    }

    @media (max-width: 679px) {
      .tools-step { grid-template-columns: 2.5rem 1fr; }
      .tools-step-link { grid-column: 2; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { scroll-behavior: auto !important; }
    }
  </style>
</Base>
