---
import Base from '../../layouts/Base.astro';
// Calculator definitions + math live in src/data/leak-calculators.ts, shared
// with the MCP server so on-page and in-agent numbers can't drift.
import { CALCS } from '../../data/leak-calculators';

const metaDescription =
  'Put a dollar figure on your worst operational leak in about a minute. Ten calculators: missed calls, slow bids, unbilled change orders, unanswered inquiries, slow quotes, no-shows, first-reply speed, and invoice aging.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'The Leak Calculator',
      url: 'https://builtwithjon.com/tools/leak-calculator/',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description: metaDescription,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://builtwithjon.com/' },
        { '@type': 'ListItem', position: 2, name: 'Leak Calculator', item: 'https://builtwithjon.com/tools/leak-calculator/' },
      ],
    },
  ],
};

---

<Base title="The Leak Calculator" description={metaDescription} schema={schema}>
  <section class="lc-hero">
    <p class="eyebrow">Free tool</p>
    <h1>The Leak Calculator</h1>
    <p class="lede">
      Every operational leak has a dollar figure. Most owners never compute it, so the leak loses to whatever is loud today.
      Pick your leak, enter three or four numbers you already know, and get a monthly and annual estimate you can prioritize against.
    </p>
  </section>

  <div
    class="starter-gate"
    id="starter-gate"
    data-kit="leak-calculator"
  >
    <p class="starter-gate-label">Free tool, unlocked by email</p>
    <p class="starter-gate-lede">Enter your email and the calculator opens right here. I send the occasional note on fixing operational leaks. No spam, unsubscribe anytime.</p>
    <form
      class="starter-gate-form"
      id="starter-gate-form"
      action="https://formspree.io/f/xdapgpae"
      method="POST"
      data-track-form="lead-magnet"
    >
      <input type="hidden" name="_subject" value="Lead magnet unlock: Leak Calculator" />
      <input type="hidden" name="inquiry_type" value="lead-magnet" />
      <input type="hidden" name="which_kit" value="leak-calculator" />
      <label for="starter-gate-email" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;">Email</label>
      <input
        type="email"
        id="starter-gate-email"
        name="email"
        class="starter-gate-input"
        placeholder="you@example.com"
        required
        autocomplete="email"
        inputmode="email"
        spellcheck="false"
      />
      <button type="submit" class="starter-gate-btn">Open the calculator</button>
    </form>
    <p class="starter-gate-error" id="starter-gate-error" hidden role="alert" aria-live="polite">
      Something went wrong. Email <a href="mailto:jonathan@builtwithjon.com">jonathan@builtwithjon.com</a> and I will send you the direct link.
    </p>
    <p class="starter-gate-note">The site is static, so nothing here is truly locked. This just lets me know who is running their numbers.</p>
  </div>

  <div class="lc-tool" id="lc-tool" hidden>
    <p class="lc-pick-label">Pick the leak that has been nagging you</p>
    <div class="lc-picker" id="lc-picker" role="tablist" aria-label="Choose a leak to calculate">
      {CALCS.map((c) => (
        <button class="lc-pick" type="button" data-calc={c.id} data-axis={c.axis} role="tab" aria-selected="false">
          <span class="lc-pick-title">{c.title}</span>
          <span class="lc-pick-seg">{c.segment}</span>
        </button>
      ))}
    </div>

    {CALCS.map((c) => (
      <section class="lc-panel" id={`lc-panel-${c.id}`} data-axis={c.axis} hidden aria-label={`${c.title} calculator`}>
        <div class="lc-panel-head">
          <h2>{c.title}</h2>
          <p class="lc-panel-seg">{c.segment}</p>
        </div>
        <p class="lc-panel-desc">{c.desc}</p>
        <div class="lc-grid">
          <div class="lc-inputs">
            {c.fields.map((f) => (
              <label class="lc-field">
                <span>{f.label}</span>
                <input
                  type="number"
                  data-calc-input={c.id}
                  data-key={f.k}
                  value={f.v}
                  min={f.min}
                  max={f.max}
                  step={f.step ?? 'any'}
                  inputmode="decimal"
                />
              </label>
            ))}
          </div>
          <div class="lc-result">
            <p class="lc-result-big" id={`lc-big-${c.id}`}>&nbsp;</p>
            <p class="lc-result-biglabel" id={`lc-biglabel-${c.id}`}>&nbsp;</p>
            <dl class="lc-result-rows" id={`lc-rows-${c.id}`}></dl>
            <p class="lc-estimate">This is an estimate from your inputs, not a measurement.</p>
          </div>
        </div>
        <p class="lc-note">{c.note}</p>
        <p class="lc-cite">{c.cite}</p>
        <p class="lc-links">
          The fix is in the article: <a href={c.article}>{c.articleTitle}</a>.
          This tool prices one leak. The <a href="/scorecard/">Hidden Profit Scorecard</a> ranks all three axes: deals, time, and cash.
        </p>
      </section>
    ))}
  </div>

  <script is:inline>
    (function () {
      var gate = document.getElementById('starter-gate');
      var tool = document.getElementById('lc-tool');
      if (!gate || !tool) return;
      var form = document.getElementById('starter-gate-form');
      var errorEl = document.getElementById('starter-gate-error');
      var btn = form ? form.querySelector('.starter-gate-btn') : null;
      var kit = gate.getAttribute('data-kit') || 'kit';
      var storeKey = 'bwj-starter-kit-' + kit;

      function reveal(justUnlocked) {
        gate.hidden = true;
        tool.hidden = false;
        if (justUnlocked) {
          if (tool.scrollIntoView) {
            tool.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
          if (window.bwjTrack) window.bwjTrack('leakcalc:unlock');
        }
      }

      try {
        if (window.localStorage && localStorage.getItem(storeKey) === 'unlocked') {
          reveal(false);
        }
      } catch (e) {}

      if (form) {
        form.addEventListener('submit', function (event) {
          event.preventDefault();
          if (errorEl) errorEl.hidden = true;
          if (btn) { btn.disabled = true; btn.textContent = 'Opening...'; }
          fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' }
          }).then(function (response) {
            if (response.ok) {
              try { if (window.localStorage) localStorage.setItem(storeKey, 'unlocked'); } catch (e) {}
              reveal(true);
              return;
            }
            throw new Error('Submission failed');
          }).catch(function () {
            if (errorEl) errorEl.hidden = false;
            if (btn) { btn.disabled = false; btn.textContent = 'Open the calculator'; }
          });
        });
      }
    })();
  </script>

  <script>
    // Bundled module script. The math lives in src/data/leak-calculators.ts,
    // shared with the MCP server's calculate_leak tool.
    import { computeLeak } from '../../data/leak-calculators';

    function recompute(id) {
      const inputs = document.querySelectorAll('[data-calc-input="' + id + '"]');
      const v = {};
      for (const input of inputs) {
        v[input.getAttribute('data-key')] = parseFloat(input.value) || 0;
      }
      const r = computeLeak(id, v);
      if (!r) return;
      const big = document.getElementById('lc-big-' + id);
      const bigLabel = document.getElementById('lc-biglabel-' + id);
      const rowsEl = document.getElementById('lc-rows-' + id);
      if (big) big.textContent = r.big;
      if (bigLabel) bigLabel.textContent = r.bigLabel;
      if (rowsEl) {
        let html = '';
        for (const row of r.rows) {
          html += '<div><dt>' + row[0] + '</dt><dd>' + row[1] + '</dd></div>';
        }
        rowsEl.innerHTML = html;
      }
    }

    const picks = document.querySelectorAll('.lc-pick');
    function show(id) {
      const panels = document.querySelectorAll('.lc-panel');
      for (const panel of panels) panel.hidden = true;
      for (const pick of picks) {
        const active = pick.getAttribute('data-calc') === id;
        pick.classList.toggle('lc-pick-active', active);
        pick.setAttribute('aria-selected', active ? 'true' : 'false');
      }
      const panel = document.getElementById('lc-panel-' + id);
      if (panel) {
        panel.hidden = false;
        recompute(id);
        if (panel.scrollIntoView) panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      if (window.bwjTrack) window.bwjTrack('leakcalc:pick:' + id);
    }

    for (const pick of picks) {
      pick.addEventListener('click', () => show(pick.getAttribute('data-calc')));
    }

    for (const input of document.querySelectorAll('[data-calc-input]')) {
      input.addEventListener('input', () => recompute(input.getAttribute('data-calc-input')));
    }
  </script>

  <style is:global>
    .lc-hero {
      margin: 0 0 1.5rem;
    }
    .lc-hero h1 {
      margin: 0.2rem 0 0.6rem;
    }
    .lc-tool {
      margin: 1.5rem 0 2rem;
    }
    .lc-pick-label {
      color: var(--color-copper);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin: 0 0 0.7rem;
    }
    .lc-picker {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 0.6rem;
      margin: 0 0 1.5rem;
    }
    .lc-pick {
      --axis: var(--exp-deals);
      --axis-soft: var(--exp-deals-soft);
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      text-align: left;
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--color-border);
      border-radius: 10px;
      background: var(--color-surface, #fff);
      font: inherit;
      cursor: pointer;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .lc-pick[data-axis='cash'] {
      --axis: var(--exp-cash);
      --axis-soft: var(--exp-cash-soft);
    }
    .lc-pick:hover {
      border-color: var(--axis);
    }
    .lc-pick-active {
      border-color: var(--axis);
      box-shadow: 0 0 0 2px var(--axis-soft);
    }
    .lc-pick-title {
      font-weight: 700;
      font-size: 0.95rem;
    }
    .lc-pick-seg {
      color: var(--color-text-muted);
      font-size: 0.78rem;
    }
    .lc-panel {
      --axis: var(--exp-deals);
      --axis-soft: var(--exp-deals-soft);
      border: 1px solid var(--color-border);
      border-left: 4px solid var(--axis);
      border-radius: 12px;
      background: var(--color-surface, #fff);
      padding: 1.3rem 1.4rem;
      margin: 0 0 1.5rem;
    }
    .lc-panel[data-axis='cash'] {
      --axis: var(--exp-cash);
      --axis-soft: var(--exp-cash-soft);
    }
    .lc-panel-head {
      display: flex;
      align-items: baseline;
      gap: 0.7rem;
      flex-wrap: wrap;
    }
    .lc-panel-head h2 {
      margin: 0;
      font-size: 1.3rem;
    }
    .lc-panel-seg {
      color: var(--axis);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin: 0;
    }
    .lc-panel-desc {
      color: var(--color-text-muted);
      margin: 0.4rem 0 1rem;
    }
    .lc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.2rem;
    }
    @media (max-width: 640px) {
      .lc-grid {
        grid-template-columns: 1fr;
      }
    }
    .lc-inputs {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
    }
    .lc-field {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.88rem;
    }
    .lc-field span {
      color: var(--color-text-muted);
    }
    .lc-field input {
      min-height: 42px;
      padding: 0.45rem 0.65rem;
      border: 1px solid var(--color-border);
      border-radius: 6px;
      background: #fff;
      color: var(--color-text);
      font: inherit;
      font-variant-numeric: tabular-nums;
    }
    .lc-field input:focus {
      outline: 2px solid var(--axis-soft);
      border-color: var(--axis);
    }
    .lc-result {
      border: 1px solid var(--axis-soft);
      border-radius: 10px;
      background: var(--color-paper, #fbf6ec);
      padding: 1rem 1.1rem;
      align-self: start;
    }
    .lc-result-big {
      font-size: 2rem;
      font-weight: 800;
      color: var(--axis);
      margin: 0;
      font-variant-numeric: tabular-nums;
    }
    .lc-result-biglabel {
      color: var(--color-text-muted);
      font-size: 0.85rem;
      margin: 0.1rem 0 0.8rem;
    }
    .lc-result-rows {
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .lc-result-rows div {
      display: flex;
      justify-content: space-between;
      gap: 0.8rem;
      font-size: 0.88rem;
    }
    .lc-result-rows dt {
      color: var(--color-text-muted);
    }
    .lc-result-rows dd {
      margin: 0;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .lc-estimate {
      color: var(--color-text-muted);
      font-size: 0.75rem;
      font-style: italic;
      margin: 0.9rem 0 0;
    }
    .lc-note {
      font-size: 0.9rem;
      margin: 1.1rem 0 0.4rem;
    }
    .lc-cite {
      color: var(--color-text-muted);
      font-size: 0.8rem;
      margin: 0 0 0.4rem;
    }
    .lc-links {
      font-size: 0.9rem;
      margin: 0.6rem 0 0;
    }
  </style>
</Base>
