---
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { customArticles } from '../../data/customArticles';
import multipleEmailHero from '../../assets/articles/multiple-email-accounts-with-claude/option-c-whiteboard-v3.png';

const contentArticles = (await getCollection('articles', ({ data }) => !data.draft))
  .map((article) => ({
    title: article.data.title,
    slug: article.id,
    date: article.data.date,
    description: article.data.description,
    story: article.data.story,
    image: undefined,
    imageAlt: undefined,
  }));

const designedArticles = customArticles.map((article) => ({
  ...article,
  image: article.slug === 'multiple-email-accounts-with-claude' ? multipleEmailHero : undefined,
}));

const articles = [...designedArticles, ...contentArticles]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<Base
  title="Articles"
  description="Articles on Claude Code, AI operations, implementation strategy, and building practical automation systems."
>
  <div class="container">
    <h1>Articles</h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
      Long-form writing about AI infrastructure, implementation strategy, and how to make automation useful in day-to-day operations.
    </p>
    {articles.map((article) => (
      <ArticleCard
        title={article.title}
        slug={article.slug}
        date={article.date}
        description={article.description}
        story={article.story}
        image={article.image}
        imageAlt={article.imageAlt}
      />
    ))}
  </div>
</Base>
