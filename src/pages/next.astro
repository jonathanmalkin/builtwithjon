---
import Base from '../layouts/Base.astro';

const bookingUrl = 'https://calendar.app.google/rC9Kz37aZANXAUgt5';
const formEndpoint = 'https://formspree.io/f/xdapgpae';
const thanksUrl = '/next/thanks';
---

<Base
  title="What's Next for Your Agent?"
  description="Tell Jonathan where you want to take your AI assistant next. It shapes the next workshop — and he'll follow up personally."
>
  <div class="container next-page">
    <div class="next-intro panel">
      <p class="eyebrow">What's Next</p>
      <h1>What's next for your agent?</h1>
      <p class="lede">
        You built an assistant that knows you. The next step is getting your
        data and workflows in line so it can actually run them.
      </p>
      <p class="next-intro-meta">Three questions, 30 seconds &mdash; and I'll follow up with you personally.</p>
    </div>

    <form
      id="next-survey"
      action={formEndpoint}
      method="POST"
      class="next-form panel"
      data-thanks={thanksUrl}
    >
      <input type="hidden" name="_subject" value="Workshop survey — What's Next" />
      <input type="hidden" name="inquiry_type" value="workshop-next-survey" />

      <div class="form-group next-email">
        <label for="email">Your email</label>
        <p class="form-hint">So I can send you the right next step.</p>
        <input type="email" id="email" name="email" required class="form-input" placeholder="you@company.com" />
      </div>

      <fieldset class="next-fieldset">
        <legend>What would help your business next?</legend>
        <p class="form-hint">Check all that apply.</p>
        <div class="option-grid">
          <label class="option-chip">
            <input type="checkbox" name="help_with" value="Organizing my data" />
            <span>Organizing my data so my agent can use it</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="help_with" value="Automating a workflow" />
            <span>Automating a workflow <em>(pick which below)</em></span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="help_with" value="Workshop for my team or company" />
            <span>A workshop for my whole team or company</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="help_with" value="Don't know where to start" />
            <span>I don't know where to start &mdash; let's talk</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="next-fieldset">
        <legend>Which workflows would you want to automate?</legend>
        <p class="form-hint">Check all that apply.</p>
        <div class="option-grid option-grid-two">
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Email & follow-up" />
            <span>Email &amp; follow-up</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Calendar & scheduling" />
            <span>Calendar &amp; scheduling</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Sales outreach" />
            <span>Sales outreach</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Marketing & content" />
            <span>Marketing &amp; content</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Accounting & bookkeeping" />
            <span>Accounting &amp; bookkeeping</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Client / customer communication" />
            <span>Client / customer communication</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Project & task organization" />
            <span>Project &amp; task organization</span>
          </label>
          <label class="option-chip">
            <input type="checkbox" name="workflows" value="Daily accountability & reminders" />
            <span>Daily accountability &amp; reminders</span>
          </label>
        </div>
        <div class="form-group form-other">
          <label for="workflow_other">Something else?</label>
          <input type="text" id="workflow_other" name="workflow_other" class="form-input" placeholder="Another workflow you'd automate" />
        </div>
      </fieldset>

      <div class="next-actions">
        <button type="submit" class="form-submit next-submit">Send it &rarr;</button>
        <p class="next-error" hidden role="alert">Something went wrong &mdash; please try again, or just <a href={bookingUrl}>book a quick call</a>.</p>
      </div>
    </form>

    <p class="next-talk">
      Prefer to just talk it through? <a href={bookingUrl}>Book 15 minutes with me &rarr;</a>
    </p>
  </div>

  <script is:inline define:vars={{ thanksUrl }}>
    const form = document.getElementById('next-survey');
    if (form) {
      const submitBtn = form.querySelector('.next-submit');
      const errorEl = form.querySelector('.next-error');
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (errorEl) errorEl.hidden = true;
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending…';
        }
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (response.ok) {
            window.location.assign(thanksUrl);
            return;
          }
          throw new Error('Submission failed');
        } catch (err) {
          if (errorEl) errorEl.hidden = false;
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send it →';
          }
        }
      });
    }
  </script>
</Base>
