---
import Base from '../layouts/Base.astro';

// The free front door: a 9-question, segmented "leak score" (deals/time/cash).
// On-screen result is the teaser; the email (Resend, deterministic template,
// approval-gated) is the deliverable. Lead also routes to Formspree -> CRM.
// Spec: Workspace/01-Strategy/Active/2026-06-12-builtwithjon-scorecard-spec.md
// Copy: ...-builtwithjon-scorecard-copy.md  Email: ...-scorecard-email-report-spec.md

const formEndpoint = 'https://formspree.io/f/xdapgpae'; // same closed path as other forms -> inbox -> CRM
---

<Base
  title="AI Workflow Scorecard"
  description="A 3-minute scorecard. Find out where your business is leaking deals, time, and cash, and the one fix worth doing first."
>
  <section class="sc-stage" aria-labelledby="sc-h">
    <div class="sc-card" id="sc-app">
      <header class="sc-top">
        <p class="sc-eyebrow"><span class="sc-spark" aria-hidden="true"></span> The 3-minute scorecard</p>
        <h1 id="sc-h" class="sc-title">Where is your business leaking <em class="sc-w-deals">deals</em>, <em class="sc-w-time">time</em>, and <em class="sc-w-cash">cash</em>?</h1>
        <div class="sc-progress" aria-hidden="true"><span class="sc-progress-bar" id="sc-bar"></span></div>
        <p class="sc-step-meta"><span id="sc-step-n">Question 1 of 9</span><span id="sc-step-axis" class="sc-axis"></span></p>
      </header>

      <div id="sc-question" class="sc-body" aria-live="polite"></div>

      <footer class="sc-foot">
        <button type="button" class="sc-back" id="sc-back" hidden>&larr; Back</button>
        <span class="sc-foot-note" id="sc-foot-note">No call, no pitch. Free.</span>
      </footer>
    </div>

    <noscript>
      <p class="sc-noscript">The scorecard needs JavaScript. You can also just email
        <a href="mailto:jonathan@builtwithjon.com">jonathan@builtwithjon.com</a> the one workflow slowing you down.</p>
    </noscript>
  </section>

  <script is:inline define:vars={{ formEndpoint }}>
    // ---- Data model (mirrors the spec). Pure data + deterministic scoring. No model. ----
    // Q1 is INDUSTRY only. The deals/time/cash axes already capture the functional
    // dimension (sales, admin, finance, etc.), so those are NOT segment choices.
    // 'general' is the universal-benchmark fallback for owners outside the verticals.
    const SEGMENTS = [
      ['gc','General contracting'],['re','Real estate'],['hs','Home services & trades'],
      ['pm','Property management'],['ps','Professional services'],['hw','Health & wellness'],
      ['cc','Coaching or creator'],['general','Something else / general business'],
    ];

    // Each scored option carries a leak weight 0..3 (higher = more leak) on its axis.
    const QUESTIONS = [
      { id:'segment', axis:null, q:'What kind of business is this?', help:'Pick the closest. It changes how we read your answers.',
        options: SEGMENTS.map(([v,l]) => ({ v, l, w:0 })) },
      { id:'q2', axis:'deals', q:'A new lead comes in. How fast does someone respond?',
        options:[['Within minutes',0],['Same day',1],['A day or two',2],["Honestly, it's inconsistent",3]] },
      { id:'q3', axis:'deals', q:"A lead doesn't buy right away. Then what?",
        options:[['They go into a follow-up sequence that runs on its own',0],['Someone follows up manually, when they remember',2],['Usually nothing',3],['Not sure',2]] },
      { id:'q4', axis:'deals', q:'Roughly how many new leads or inquiries come in a month?', mag:'volume',
        options:[['Under 10',0],['10 to 50',1],['50 to 200',2],['More than 200',3]] },
      { id:'q5', axis:'time', q:'How many hours a week do you spend on admin, chasing status, and re-typing the same information?', mag:'hours',
        options:[['A few',0],['Around 5 to 10',1],['10 to 20',2],['More than I want to admit',3]] },
      { id:'q6', axis:'time', q:'How much of your work lives across separate tools you copy between by hand?',
        options:[["It's mostly connected",0],['Some manual copying',1],['A lot of manual copying',2],["It's all held together by hand",3]] },
      { id:'q7', axis:'time', q:'How often does work get redone because of a miss, a gap, or bad information?',
        options:[['Rarely',0],['A few times a month',1],['Most weeks',2],['Constantly',3]] },
      { id:'q8', axis:'cash', q:'After work is done, how fast do you invoice and get paid?',
        options:[['Right away, mostly automated',0],['Within a week',1],['Slow and manual',2],['It slips, and some of it never gets chased',3]] },
      { id:'q9', axis:'cash', q:"Last one, and you can skip it. Roughly, what's monthly revenue?", help:"Skip it and we'll show your leaks as percentages instead of dollars.", mag:'revenue', optional:true,
        options:[['Under $25k',0],['$25k to $100k',1],['$100k to $500k',1],['More than $500k',1],['Skip',0]] },
    ];

    // Industry one-liners (deals/time/cash). 'general' is the universal fallback
    // for owners outside the named verticals, grounded in the universal benchmarks.
    const LINES = {
      gc:{deals:'Bids and follow-ups are slipping between the field and the office.',time:'Too much of the week goes to chasing information instead of building.',cash:'Slow invoicing and rework are eating margin you already earned.'},
      re:{deals:"The first agent to respond usually wins, and you're not always first.",time:'Non-revenue admin and document wrangling are eating hours that should be in front of clients.',cash:'Deals fall through in the gaps in follow-through, not in pricing.'},
      hs:{deals:'Calls that hit voicemail go straight to the next contractor on the list.',time:'Intake and quoting are getting squeezed between jobs, so follow-up slips.',cash:'Jobs are done but the invoice chase drags, and some of it never gets chased.'},
      pm:{deals:'Leasing inquiries are slipping before anyone follows up.',time:'The same handful of recurring problems eat the week on a loop.',cash:'Rent chasing and late payments are a standing drain on the month.'},
      ps:{deals:'Inquiries are going unanswered, and prospects book whoever replied first.',time:'Too much expert time is non-billable, reconstructing and re-drafting from scratch.',cash:'Invoices and engagement letters drag, so earned fees collect slowly.'},
      hw:{deals:"New callers who reach voicemail don't call back, they book elsewhere.",time:'Insurance and intake admin are eating clinical hours.',cash:'No-shows and unfilled slots are leaving revenue in empty chairs.'},
      cc:{deals:"Leads that found you are going unanswered while you're heads-down creating.",time:'Packaging and posting are eating the hours that should go to the work only you can do.',cash:'Churn and refunds are leaking revenue you already won.'},
      general:{deals:'Leads are going cold before anyone answers. Odds of even qualifying a lead drop sharply between a 5-minute and a 30-minute reply.',time:'Too much of the week goes to status-chasing and re-typing the same thing between disconnected tools.',cash:'Invoices and collections are slipping, and money you earned is sitting uncollected.'},
    };

    const TIERS = [
      { key:'holding', label:'Holding', verdict:'Your systems are mostly holding. The leaks here are small, and most of the win is sharpening what already works.' },
      { key:'leaking', label:'Leaking', verdict:"There are real, fixable losses here. A couple of spots are quietly costing you, and they're the kind of thing that's fixable without ripping anything out." },
      { key:'wideopen', label:'Wide open', verdict:'A lot is getting through the gaps. Deals, hours, and cash are leaking in more than one place. The good news: that also means the first fix pays for itself fast.' },
    ];

    const answers = {};
    let idx = 0;

    const el = (id) => document.getElementById(id);
    const qEl = el('sc-question'), bar = el('sc-bar'), stepN = el('sc-step-n'),
          stepAxis = el('sc-step-axis'), backBtn = el('sc-back');

    const AXIS_LABEL = { deals:'Deal leak', time:'Time leak', cash:'Cash leak' };
    const AXIS_ICON = { deals:'&#9889;', time:'&#9201;', cash:'&#128176;', segment:'&#127919;' }; // bolt, timer, money bag, target
    const card = document.getElementById('sc-app');

    function renderQuestion() {
      const item = QUESTIONS[idx];
      const axisKey = item.axis || 'segment';
      card.setAttribute('data-axis', axisKey);
      bar.style.width = Math.round(((idx) / QUESTIONS.length) * 100) + '%';
      stepN.textContent = `Question ${idx + 1} of ${QUESTIONS.length}`;
      stepAxis.innerHTML = item.axis ? `<span class="sc-chip-ico">${AXIS_ICON[item.axis]}</span> ${AXIS_LABEL[item.axis]}` : '';
      backBtn.hidden = idx === 0;

      let html = `<p class="sc-q"><span class="sc-q-ico" aria-hidden="true">${AXIS_ICON[axisKey]}</span>${item.q}</p>`;
      if (item.help) html += `<p class="sc-help">${item.help}</p>`;
      html += '<div class="sc-options">';
      const opts = item.options.map((o) => Array.isArray(o) ? { l:o[0], w:o[1] } : o);
      opts.forEach((o, i) => {
        const val = o.v || o.l;
        const sel = answers[item.id] && answers[item.id].value === val ? ' is-selected' : '';
        html += `<button type="button" class="sc-option${sel}" data-i="${i}"><span class="sc-opt-dot" aria-hidden="true"></span><span>${o.l}</span></button>`;
      });
      html += '</div>';
      qEl.innerHTML = html;

      qEl.querySelectorAll('.sc-option').forEach((btn) => {
        btn.addEventListener('click', () => {
          const o = opts[Number(btn.dataset.i)];
          answers[item.id] = { value: o.v || o.l, w: o.w, label: o.l };
          next();
        });
      });
    }

    function next() {
      if (idx < QUESTIONS.length - 1) { idx++; renderQuestion(); }
      else { showResult(); }
    }
    backBtn.addEventListener('click', () => { if (idx > 0) { idx--; renderQuestion(); } });

    function axisScore(axis) {
      // average leak weight on the axis -> 0..100. Magnitude questions (volume,
      // revenue) scale dollar estimates, they are NOT leak signals, so they are
      // excluded here: a skipped/low revenue answer must never lower a cash leak.
      const items = QUESTIONS.filter((x) => x.axis === axis && !x.mag && answers[x.id]);
      if (!items.length) return 0;
      const sum = items.reduce((a, x) => a + (answers[x.id].w || 0), 0);
      return Math.round((sum / (items.length * 3)) * 100);
    }
    function tierFor(score) { return score >= 60 ? TIERS[2] : score >= 30 ? TIERS[1] : TIERS[0]; }

    function showResult() {
      bar.style.width = '100%';
      const seg = answers.segment ? answers.segment.value : 'general';
      const lines = LINES[seg] || LINES.general;
      const axes = ['deals','time','cash'].filter((a) => lines[a]); // personal skips deals
      const scores = {}; axes.forEach((a) => scores[a] = axisScore(a));
      const composite = Math.round(axes.reduce((s,a) => s + scores[a], 0) / axes.length);
      const tier = tierFor(composite);
      const worst = axes.slice().sort((a,b) => scores[b] - scores[a])[0];

      stepN.textContent = 'Your result'; stepAxis.innerHTML = '';
      backBtn.hidden = true;
      card.setAttribute('data-axis', 'result');
      bar.style.width = '100%';

      const axisRow = (a) => {
        const t = tierFor(scores[a]);
        return `<div class="sc-axis-row" data-axis="${a}">
          <div class="sc-axis-head"><span class="sc-axis-name"><span class="sc-axis-ico" aria-hidden="true">${AXIS_ICON[a]}</span>${a[0].toUpperCase()+a.slice(1)}</span><span class="sc-axis-tier">${t.label}</span></div>
          <div class="sc-axis-track"><span class="sc-axis-fill" style="width:${Math.max(8,scores[a])}%"></span></div>
          <p class="sc-axis-line">${lines[a]}</p>
        </div>`;
      };

      qEl.innerHTML = `
        <div class="sc-result">
          <div class="sc-result-head">
            <span class="sc-tier sc-tier-${tier.key}">${tier.label}</span>
          </div>
          <p class="sc-verdict">${tier.verdict}</p>
          <div class="sc-axes">${axes.map(axisRow).join('')}</div>
          <div class="sc-biggest">
            <strong>Your biggest leak right now:</strong> ${lines[worst].replace(/\.$/, '')}. For a ${answers.segment.label.toLowerCase()} business, that's usually the most expensive one to leave alone.
          </div>
          <div class="sc-gate">
            <p class="sc-gate-h">Want the full breakdown?</p>
            <p class="sc-gate-sub">I'll show the rough size of each leak, and where to start. It's an estimate from your answers and ${answers.segment.label.toLowerCase()} benchmarks. The audit measures it for real.</p>
            <form id="sc-gate-form" action="${formEndpoint}" method="POST" novalidate>
              <input type="hidden" name="_subject" value="Scorecard lead" />
              <input type="hidden" name="inquiry_type" value="scorecard-lead" />
              <input type="hidden" name="segment" value="${answers.segment.value}" />
              <input type="hidden" name="tier" value="${tier.label}" />
              <input type="hidden" name="scores" value='${JSON.stringify(scores)}' />
              <input type="hidden" name="answers" value='${JSON.stringify(Object.fromEntries(Object.entries(answers).map(([k,v]) => [k, v.label])))}' />
              <div class="sc-gate-fields">
                <input type="text" name="name" placeholder="First name" autocomplete="given-name" class="sc-input" aria-label="First name" />
                <input type="email" name="email" required placeholder="you@company.com" autocomplete="email" class="sc-input" aria-label="Email" />
              </div>
              <button type="submit" class="sc-submit">Show me the breakdown</button>
              <p class="sc-privacy">Your email gets your breakdown and the occasional implementation note. Nothing else. <a href="/privacy">Privacy policy</a>.</p>
              <p class="sc-gate-error" hidden role="alert">That didn't go through. Try again, or email <a href="mailto:jonathan@builtwithjon.com">jonathan@builtwithjon.com</a> and I'll send your breakdown myself.</p>
            </form>
          </div>
        </div>`;

      wireGate();
    }

    function wireGate() {
      const form = el('sc-gate-form');
      if (!form) return;
      const btn = form.querySelector('.sc-submit');
      const errEl = form.querySelector('.sc-gate-error');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (errEl) errEl.hidden = true;
        btn.disabled = true; btn.textContent = 'Reading your answers...';
        try {
          // Formspree -> inbox -> CRM. (Resend personalized report is a SEPARATE,
          // APPROVAL-GATED server send, wired at build time. Not called here yet.)
          const res = await fetch(form.action, { method:'POST', body:new FormData(form), headers:{ Accept:'application/json' } });
          if (!res.ok) throw new Error('failed');
          showThanks(form);
        } catch (err) {
          if (errEl) errEl.hidden = false;
          btn.disabled = false; btn.textContent = 'Show me the breakdown';
        }
      });
    }

    function showThanks(form) {
      form.outerHTML = `<div class="sc-thanks">
        <p class="sc-gate-h">On its way.</p>
        <p>Your breakdown is headed to your inbox. While you wait, the audit is how these estimates become measured numbers with your real data.</p>
        <div class="sc-cta-row">
          <a href="/ai-workflow-audit/" class="sc-cta">See how the audit works &rarr;</a>
          <a href="/use-cases/" class="sc-cta sc-cta-soft">Or browse the use cases</a>
        </div>
      </div>`;
    }

    renderQuestion();
  </script>

  <style is:global>
    /* ---- QUESTION mode: viewport-fit card, no scroll. The card fits the viewport
       below the site header so a question never requires scrolling.
       RESULT mode (.sc-card[data-axis="result"]): the height cap and inner scroll
       are released so the result flows down the page with ONE page-level scrollbar,
       never a nested card scroll. ---- */
    .site-header { margin-bottom: 0 !important; }
    .sc-stage {
      min-height: calc(100svh - 6rem);
      display: flex; align-items: center; justify-content: center;
      padding: clamp(0.5rem, 1.5vh, 1rem) 1rem;
      box-sizing: border-box;
    }
    .sc-card {
      --axis: var(--color-copper);
      --axis-soft: #f3e0d4;
      width: 100%; max-width: 560px;
      max-height: calc(100svh - 4.25rem);
      display: flex; flex-direction: column;
      background: var(--color-surface);
      border: 1px solid var(--color-foam-line);
      border-radius: 18px;
      box-shadow: 0 12px 40px -24px rgba(31,23,19,0.45);
      overflow: hidden;
    }
    /* result: let it grow and flow on the page, no inner scroll */
    .sc-stage:has(.sc-card[data-axis="result"]) { align-items: flex-start; min-height: 0; padding-top: clamp(1rem, 3vh, 2rem); }
    .sc-card[data-axis="result"] { max-width: 620px; max-height: none; overflow: visible; }
    .sc-card[data-axis="result"] .sc-body { overflow-y: visible; }
    /* per-axis theming, drives bar + icons + option accents */
    .sc-card[data-axis="segment"] { --axis: var(--color-plum); --axis-soft: #efe2ea; }
    .sc-card[data-axis="deals"]   { --axis: var(--color-jules-orange); --axis-soft: #fbe6d6; }
    .sc-card[data-axis="time"]    { --axis: var(--color-blue-mug); --axis-soft: #dfeaf1; }
    .sc-card[data-axis="cash"]    { --axis: var(--color-sage); --axis-soft: #e2ebe2; }
    .sc-card[data-axis="result"] { --axis: var(--color-copper); --axis-soft: #f3e0d4; }

    .sc-top { padding: clamp(0.6rem, 2vh, 1.1rem) 1.4rem clamp(0.55rem, 1.5vh, 0.9rem); background-color: var(--axis-soft); transition: background-color 0.45s ease; }
    /* keep the header wash calm during questions; only the bar/icons carry the axis hue.
       the wash still shifts to copper on the result for a subtle payoff moment. */
    .sc-card[data-axis="segment"] .sc-top,
    .sc-card[data-axis="deals"] .sc-top,
    .sc-card[data-axis="time"] .sc-top,
    .sc-card[data-axis="cash"] .sc-top { background-color: #f1ece2; }
    .sc-eyebrow { display: flex; align-items: center; gap: 0.45rem; color: var(--axis); font-family: var(--font-mono); font-size: 0.68rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 clamp(0.3rem, 1vh, 0.5rem); }
    .sc-spark { width: 8px; height: 8px; border-radius: 999px; background: var(--axis); box-shadow: 0 0 0 4px color-mix(in srgb, var(--axis) 22%, transparent); }
    .sc-title { font-size: clamp(1.05rem, 2.6vh + 0.4rem, 1.6rem); line-height: 1.1; margin: 0 0 clamp(0.5rem, 1.5vh, 0.85rem); font-weight: 700; }
    .sc-title em { font-style: normal; }
    .sc-w-deals { color: var(--color-jules-orange); }
    .sc-w-time { color: var(--color-blue-mug); }
    .sc-w-cash { color: var(--color-sage); }
    .sc-progress { height: 6px; background: rgba(31,23,19,0.10); border-radius: 999px; overflow: hidden; margin-bottom: 0.55rem; }
    .sc-progress-bar { display: block; height: 100%; width: 0; background-color: var(--axis); border-radius: 999px; transition: width 0.3s ease; }
    .sc-step-meta { display: flex; justify-content: space-between; align-items: center; font-size: 0.72rem; color: var(--color-text-muted); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.05em; margin: 0; }
    .sc-axis { display: inline-flex; align-items: center; gap: 0.35rem; color: var(--axis); font-weight: 800; }
    .sc-chip-ico { font-size: 0.95rem; }

    .sc-body { flex: 1 1 auto; overflow-y: auto; padding: clamp(0.75rem, 2vh, 1.2rem) 1.4rem; -webkit-overflow-scrolling: touch; }
    .sc-q { display: flex; gap: 0.5rem; font-size: clamp(1rem, 2.4vh + 0.3rem, 1.3rem); line-height: 1.25; font-weight: 700; margin: 0 0 0.3rem; }
    .sc-q-ico { font-size: 1.15rem; flex: 0 0 auto; line-height: 1.2; }
    .sc-help { font-size: 0.86rem; color: var(--color-text-muted); margin: 0 0 clamp(0.55rem, 1.5vh, 0.9rem); }
    .sc-options { display: flex; flex-direction: column; gap: clamp(0.35rem, 1vh, 0.5rem); margin-top: clamp(0.55rem, 1.5vh, 0.9rem); }
    .sc-option { display: flex; align-items: center; gap: 0.7rem; text-align: left; padding: clamp(0.45rem, 1.2vh, 0.7rem) 0.95rem; border: 1.5px solid var(--color-foam-line); border-radius: 12px; background: var(--color-bg); font-size: 0.95rem; color: var(--color-text); cursor: pointer; transition: border-color 0.15s, background 0.15s, transform 0.08s; }
    .sc-opt-dot { width: 10px; height: 10px; border-radius: 999px; border: 2px solid var(--color-foam-line); flex: 0 0 auto; transition: border-color 0.15s, background 0.15s; }
    .sc-option:hover, .sc-option:focus-visible { border-color: var(--axis); background: var(--color-surface); outline: none; }
    .sc-option:hover .sc-opt-dot, .sc-option:focus-visible .sc-opt-dot { border-color: var(--axis); background: var(--axis); }
    .sc-option:active { transform: scale(0.99); }
    .sc-option.is-selected { border-color: var(--axis); background: var(--axis-soft); }
    .sc-option.is-selected .sc-opt-dot { border-color: var(--axis); background: var(--axis); }

    .sc-foot { display: flex; justify-content: space-between; align-items: center; padding: clamp(0.5rem, 1.3vh, 0.75rem) 1.4rem; border-top: 1px solid var(--color-foam-line); background: var(--color-surface); }
    .sc-back { background: none; border: none; color: var(--color-text-muted); font-size: 0.85rem; cursor: pointer; padding: 0; }
    .sc-back:hover { color: var(--axis); }
    .sc-foot-note { font-size: 0.78rem; color: var(--color-text-muted); margin-left: auto; }

    /* ---- result ---- */
    .sc-result-head { margin-bottom: 0.6rem; }
    .sc-tier { display: inline-block; font-family: var(--font-mono); font-size: 0.78rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.35rem 0.9rem; border-radius: 999px; }
    .sc-tier-holding { background: #e3efe3; color: #3d5e3d; }
    .sc-tier-leaking { background: #faecd0; color: #8f6a24; }
    .sc-tier-wideopen { background: #fbe1d4; color: #b3471a; }
    .sc-verdict { font-size: 1rem; line-height: 1.5; color: var(--color-text); margin: 0 0 1.1rem; }

    .sc-axes { display: flex; flex-direction: column; gap: 0.85rem; }
    .sc-axis-row { --axis: var(--color-copper); }
    .sc-axis-row[data-axis="deals"] { --axis: var(--color-jules-orange); }
    .sc-axis-row[data-axis="time"] { --axis: var(--color-blue-mug); }
    .sc-axis-row[data-axis="cash"] { --axis: var(--color-sage); }
    .sc-axis-head { display: flex; justify-content: space-between; align-items: center; font-size: 0.92rem; font-weight: 700; margin-bottom: 0.3rem; }
    .sc-axis-name { display: inline-flex; align-items: center; gap: 0.4rem; }
    .sc-axis-ico { font-size: 0.95rem; }
    .sc-axis-tier { color: var(--axis); font-weight: 800; font-size: 0.82rem; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.04em; }
    .sc-axis-track { height: 9px; background: rgba(31,23,19,0.08); border-radius: 999px; overflow: hidden; }
    .sc-axis-fill { display: block; height: 100%; border-radius: 999px; background: var(--axis); transition: width 0.5s ease; }
    .sc-axis-line { font-size: 0.86rem; color: var(--color-text-muted); margin: 0.35rem 0 0; line-height: 1.4; }

    .sc-biggest { background: var(--axis-soft); border-left: 4px solid var(--axis); border-radius: 0 10px 10px 0; padding: 0.85rem 1rem; font-size: 0.95rem; line-height: 1.45; margin: 1.1rem 0; }
    .sc-gate { border-top: 1px solid var(--color-foam-line); padding-top: 1.1rem; margin-top: 1.1rem; }
    .sc-gate-h { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.4rem; }
    .sc-gate-sub { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.45; margin: 0 0 0.9rem; }
    .sc-gate-fields { display: flex; gap: 0.5rem; margin-bottom: 0.6rem; flex-wrap: wrap; }
    .sc-input { flex: 1 1 160px; padding: 0.65rem 0.85rem; border: 1.5px solid var(--color-foam-line); border-radius: 9px; background: var(--color-bg); font-size: 0.98rem; color: var(--color-text); }
