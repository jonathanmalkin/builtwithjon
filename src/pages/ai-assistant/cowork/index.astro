    summary::-webkit-details-marker { display: none; }
    summary::after { content: "+"; color: var(--blue); font-weight: 800; font-size: 1.2rem; }
    details[open] summary::after { content: "-"; }
    .detail-body { padding: 0 20px 20px; border-top: 1px solid var(--line); }
    .detail-body ol, .detail-body ul { margin: 16px 0 0; padding-left: 1.35rem; }
    .prompt {
      position: relative;
      display: block;
      margin-top: 10px;
      padding: 14px 96px 14px 16px;
      border: 1px solid var(--line);
      border-left: 4px solid var(--blue);
      border-radius: 8px;
      background: #fcf7ee;
      color: var(--ink);
