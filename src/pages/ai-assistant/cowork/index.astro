      border-radius: 8px;
      background: #fdf3e6;
    }
    .note-warn p:last-child { margin-bottom: 0; }
    .shot {
      display: block;
      margin-top: 14px;
      border: 1px dashed #c9b79c;
      border-radius: 8px;
      padding: 22px 16px;
      text-align: center;
      color: var(--umber);
      background: #fffaf1;
      font-size: 0.92rem;
    }
    .shot strong { color: var(--copper); }
    .feedback-table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--porcelain);
      box-shadow: var(--shadow);
    }
    .feedback-table th, .feedback-table td {
      padding: 16px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }
    .feedback-table th {
      color: var(--ink);
      background: #f5ead8;
      font-size: 0.9rem;
    }
    .feedback-table tr:last-child td { border-bottom: 0; }
    .compare th:first-child, .compare td:first-child { width: 18%; color: var(--ink); font-weight: 720; }
    .compare .good, .compare .con, .compare .neutral { font-weight: 750; font-size: 0.82rem; }
    .compare .good { color: var(--sage); }
    .compare .con { color: var(--copper); }
    .compare .neutral { color: var(--plum); }
