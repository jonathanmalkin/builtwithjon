    .tag a, .status a { color: inherit; text-decoration-color: currentColor; }
    .sage { background: var(--sage); color: var(--ink); }
    .plum { background: var(--plum); }
    .copper { background: var(--copper); }
    code, pre { font-family: var(--mono); }
