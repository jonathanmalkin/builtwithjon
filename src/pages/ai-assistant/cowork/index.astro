      overflow-x: auto;
      margin: 12px 0 0;
      padding: 52px 18px 18px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fcf7ee;
      color: var(--ink);
      font-size: 0.9rem;
      line-height: 1.62;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }
    pre code { padding: 0; background: transparent; color: inherit; font-size: inherit; font-family: var(--sans); }
    details { margin-bottom: 12px; overflow: hidden; }
    summary {
