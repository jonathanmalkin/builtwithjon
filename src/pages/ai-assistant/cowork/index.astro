    .copy-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 11px;
      border: 1px solid var(--line);
      border-radius: 7px;
      background: #fffdf8;
      color: var(--blue-strong);
      font: 700 0.8rem/1 var(--sans);
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .copy-btn:hover { background: #f5ead8; }
    .copy-btn:focus-visible { outline: 3px solid var(--orange); outline-offset: 2px; }
    .copy-btn.copied { background: var(--sage); color: #fff; border-color: var(--sage); }
    pre .copy-btn { top: 12px; right: 12px; }
