---
import Base from '../../layouts/Base.astro';

const metaDescription =
  'A free swipe file of 20 ready-to-send follow-up messages: missed-call text-backs, inquiry acknowledgments, bid and quote follow-up ladders, and the invoice reminders that bridge to getting paid.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      name: 'The Follow-Up Swipe File',
      url: 'https://builtwithjon.com/kits/follow-up-swipe-file/',
      description: metaDescription,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://builtwithjon.com/' },
        { '@type': 'ListItem', position: 2, name: 'Follow-Up Swipe File', item: 'https://builtwithjon.com/kits/follow-up-swipe-file/' },
      ],
    },
  ],
};
---

<Base title="The Follow-Up Swipe File" description={metaDescription} schema={schema}>
  <section class="kit-hero">
    <p class="eyebrow">Free swipe file</p>
    <h1>The Follow-Up Swipe File</h1>
    <p class="lede">
      20 ready-to-send messages for the moments leads go cold. Follow-up fails at the blank page, not at the intention.
      This file removes the blank page: copy, adapt to how you actually talk, send.
    </p>
  </section>

  <section class="kit-inside" aria-label="What is inside">
    <h2>What's inside</h2>
    <ul class="kit-list">
      <li><strong>Section A: the first response.</strong> 7 acknowledgment messages that go out in minutes: missed-call text-backs, inquiry replies, DM acknowledgments, and the after-hours catch-all. Each with the timing rule attached.</li>
      <li><strong>Section B: the follow-up ladder.</strong> 7 messages on a clock: bid follow-ups at day 0, 2, and 7, same-day quotes, the two-week re-engage, and the 30-day revival.</li>
      <li><strong>Section C: the handoffs.</strong> Appointment confirmations, the post-consult recap, and the referral thank-you.</li>
      <li><strong>Section D: the cash bridge.</strong> The three invoice messages that keep sent from quietly becoming unpaid.</li>
    </ul>
    <p class="kit-guardrail">Every message carries the same rule: automation handles the speed, a human still closes the loop. Regulated conversations (medical, legal, leasing) stay informational until a person takes over.</p>
  </section>

  <div
    class="starter-gate"
    id="starter-gate"
    data-kit="follow-up-swipe-file"
    data-file="/downloads/follow-up-swipe-file.pdf"
    data-filename="follow-up-swipe-file.pdf"
  >
    <p class="starter-gate-label">Free download</p>
    <p class="starter-gate-lede">Enter your email and I will unlock the swipe file. If you want occasional practical AI notes too, opt in below.</p>
    <form
      class="starter-gate-form"
      id="starter-gate-form"
      action="/api/subscribe"
      method="POST"
      data-track-form="lead-magnet"
    >
      <input type="hidden" name="_subject" value="Lead magnet unlock: Follow-Up Swipe File" />
      <input type="hidden" name="inquiry_type" value="lead-magnet" />
      <input type="hidden" name="which_kit" value="follow-up-swipe-file" />
      <input type="hidden" name="form_id" value="kit-follow-up-swipe-file" />
      <input type="text" name="company_website" tabindex="-1" autocomplete="off" aria-hidden="true" class="form-honeypot" />
      <label for="starter-gate-email" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;">Email</label>
      <input
        type="email"
        id="starter-gate-email"
        name="email"
        class="starter-gate-input"
        placeholder="you@example.com"
        required
        autocomplete="email"
        inputmode="email"
        spellcheck="false"
      />
      <label class="form-consent form-consent-gate"><input type="checkbox" name="marketing_opt_in" value="true" /> <span>Also email me practical AI tips now and then. Optional, unsubscribe anytime.</span></label>
      <button type="submit" class="starter-gate-btn">Unlock the swipe file</button>
    </form>
    <p class="starter-gate-error" id="starter-gate-error" hidden role="alert" aria-live="polite">
      Something went wrong. Email <a href="mailto:jonathan@builtwithjon.com">jonathan@builtwithjon.com</a> and I will send it directly.
    </p>
    <p class="starter-gate-note">The site is static, so the file is not truly locked. This just lets me know who is fixing their follow-up.</p>
  </div>

  <div class="starter-gate-unlocked" id="starter-gate-unlocked" hidden>
    <p class="starter-gate-ready">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      You are in. Download is ready
    </p>
    <a class="starter-gate-download" id="starter-gate-link" href="/downloads/follow-up-swipe-file.pdf" download>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download the swipe file
    </a>
    <p class="starter-gate-download-hint">Did not start automatically? <a href="/downloads/follow-up-swipe-file.pdf" download>Click here to download <code>follow-up-swipe-file.pdf</code></a>.</p>
  </div>

  <section class="kit-next" aria-label="Related tools">
    <h2>Want the number behind the messages?</h2>
    <p>
      The <a href="/tools/leak-calculator/">Leak Calculator</a> turns your lead volume and response speed into a dollar figure in about a minute.
      The <a href="/scorecard/">Hidden Profit Scorecard</a> ranks where your operation leaks worst across deals, time, and cash.
    </p>
  </section>

  <script is:inline>
    (function () {
      var gate = document.getElementById('starter-gate');
      var unlocked = document.getElementById('starter-gate-unlocked');
      if (!gate || !unlocked) return;
      var form = document.getElementById('starter-gate-form');
      var errorEl = document.getElementById('starter-gate-error');
      var btn = form ? form.querySelector('.starter-gate-btn') : null;
      var link = document.getElementById('starter-gate-link');
      var kit = gate.getAttribute('data-kit') || 'kit';
      var storeKey = 'bwj-starter-kit-' + kit;

      function reveal(justUnlocked) {
        gate.hidden = true;
        unlocked.hidden = false;
        if (justUnlocked && link) {
          if (unlocked.scrollIntoView) {
            unlocked.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          setTimeout(function () {
            try { link.click(); } catch (e) {}
            try { link.focus(); } catch (e) {}
          }, 350);
        }
      }

      try {
        if (window.localStorage && localStorage.getItem(storeKey) === 'unlocked') {
          reveal(false);
        }
      } catch (e) {}

      if (form) {
        form.addEventListener('submit', function (event) {
          event.preventDefault();
          if (errorEl) errorEl.hidden = true;
          if (btn) { btn.disabled = true; btn.textContent = 'Unlocking...'; }
          fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' }
          }).then(function (response) {
            if (response.ok) {
              try { if (window.localStorage) localStorage.setItem(storeKey, 'unlocked'); } catch (e) {}
              reveal(true);
              return;
            }
            throw new Error('Submission failed');
          }).catch(function () {
            if (errorEl) errorEl.hidden = false;
            if (btn) { btn.disabled = false; btn.textContent = 'Unlock the swipe file'; }
          });
        });
      }
    })();
  </script>

  <style>
    .kit-hero h1 {
      margin: 0.2rem 0 0.6rem;
    }
    .kit-inside {
      margin: 1.5rem 0;
    }
    .kit-inside h2 {
      font-size: 1.15rem;
      margin: 0 0 0.6rem;
    }
    .kit-list {
      margin: 0;
      padding-left: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .kit-guardrail {
      color: var(--color-text-muted);
      font-size: 0.9rem;
      margin: 0.9rem 0 0;
    }
    .kit-next {
      margin: 2rem 0;
    }
    .kit-next h2 {
      font-size: 1.15rem;
      margin: 0 0 0.5rem;
    }
  </style>
</Base>
