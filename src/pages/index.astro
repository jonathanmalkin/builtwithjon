---
import Base from '../layouts/Base.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jonathan Malkin',
  jobTitle: 'AI Workshop Leader & Implementation Consultant',
  description: 'Jonathan Malkin runs hands-on AI workshops where teams build something real with AI against their own work, tailored to their industry and workflows.',
  url: 'https://builtwithjon.com',
  sameAs: [
    'https://github.com/jonathanmalkin',
    'https://x.com/builtwithjon',
    'https://linkedin.com/in/jonathanmalkin',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jonathan Malkin',
  url: 'https://builtwithjon.com',
  description: 'Hands-on AI workshops where your team builds something real with AI, against your own work, in a single session.',
};
---

<Base
  title="Jonathan Malkin"
  description="Hands-on AI workshops where your team builds something real with AI, against your own work, in a single session."
  schema={personSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <section class="hero-split container-wide">
    <div class="hero-split-copy">
      <p class="eyebrow">Hands-on AI workshops</p>
      <h1>AI that actually does your work.</h1>
      <p class="subtitle">
        Build a real AI workflow with your own data, hands-on, the way your team actually works. Personal assistants, sales, marketing, and more, tailored to your industry.
      </p>
      <div class="hero-links">
        <a href="/contact/" class="hero-btn">Start a conversation</a>
      </div>
    </div>
    <figure class="hero-split-media">
      <img
        src="/home/workshop-room.jpg"
        width="1600"
        height="900"
        alt="A full room of people watching Jonathan present a live AI demo on screen at AI Tinkerers in Sao Paulo."
        loading="eager"
        decoding="async"
      />
      <figcaption>Live demo at AI Tinkerers, Sao Paulo</figcaption>
    </figure>
  </section>

  <section class="container" id="what-i-do" style="margin-bottom: 3rem;">
    <h2>What the room feels like</h2>
    <p class="section-intro">
      Real tools, your own work on the screen. People who came in curious leave with something that works.
    </p>
    <div class="story-grid">
      <div class="story-card story-card-1">
        <span class="story-num">01</span>
        <div class="eyebrow">Hands-on</div>
        <h3>Build, don't watch</h3>
        <p>Your team builds the real thing during the session, with human approval gates so it never acts on its own.</p>
      </div>
      <div class="story-card story-card-2">
        <span class="story-num">02</span>
        <div class="eyebrow">Your real work</div>
        <h3>On your own data</h3>
        <p>We use your actual processes, not generic demos. You see exactly where AI helps and where it should stay out.</p>
      </div>
      <div class="story-card story-card-3">
        <span class="story-num">03</span>
        <div class="eyebrow">Something remarkable</div>
        <h3>Walk out with it</h3>
        <p>Everyone leaves with a working AI workflow and a clear view of what to build next.</p>
      </div>
    </div>
  </section>

  <section class="container why-me-grid" style="margin-bottom: 3rem;">
    <div>
      <h2>Why me</h2>
      <p class="cred-line">
        20+ years in enterprise tech, spent getting teams to actually adopt new systems, not just buy them. I run my own AI workflows every day, so the workshops teach what I already use.
      </p>
      <p><a href="/about/">More about how I work &rarr;</a></p>
    </div>
    <figure class="why-me-media">
      <img
        src="/home/jules-demo.jpg"
        width="1400"
        height="787"
        alt="Close view of a live AI assistant demo on screen, showing the presenter alongside a real-time AI avatar."
        loading="lazy"
        decoding="async"
      />
    </figure>
  </section>

  <section class="container home-final-cta">
    <p class="eyebrow">Let's talk</p>
    <h2>Want your team building with AI, not just talking about it?</h2>
    <p>
      Tell me about your team and what's slowing you down. I'll help shape the right session.
    </p>
    <div class="hero-links" style="justify-content: center;">
      <a href="/contact/" class="hero-btn">Start a conversation</a>
    </div>
  </section>
</Base>
