---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jonathan Malkin',
  jobTitle: 'AI Automation Consultant',
  description: 'AI automation consultant and product builder helping teams design workflows, internal tools, and operational systems with AI.',
  url: 'https://builtwithjon.com',
  sameAs: [
    'https://github.com/jonathanmalkin',
    'https://x.com/builtwithjon',
    'https://linkedin.com/in/jonathanmalkin',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jonathan Malkin',
  url: 'https://builtwithjon.com',
  description: 'Jonathan Malkin builds AI systems, automation workflows, and implementation plans for businesses that want practical results.',
};
---

<Base
  title="Jonathan Malkin"
  description="Jonathan Malkin builds AI systems, automation workflows, and implementation plans for businesses that want practical results."
  schema={personSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Hero -->
  <section class="hero container-wide">
    <h1>AI systems for work that still<br/>depends on human glue.</h1>
    <p class="subtitle">
      20+ years in enterprise technology. Now I help founders and small teams turn messy operations into repeatable AI-assisted systems.
    </p>
    <div class="hero-links">
      <a href="/workshops/" class="hero-btn">View Services</a>
      <a href="/contact/" class="hero-btn hero-btn-outline">Start a Project</a>
    </div>
  </section>

  <!-- What I Do -->
  <section class="container" id="what-i-do" style="margin-bottom: 3rem;">
    <h2>What I Do</h2>
    <div class="story-grid">
      <a href="/jules/" class="story-card story-card-1">
        <h3>AI Automation Systems</h3>
        <p>I build operational systems that handle recurring research, reporting, content, and workflow coordination without adding headcount.</p>
      </a>
      <a href="/workshops/" class="story-card story-card-2">
        <h3>Advisory &amp; Workshops</h3>
        <p>Discovery sessions, implementation roadmaps, and hands-on workshops that help teams find the right AI use cases and ship them safely.</p>
      </a>
      <a href="/projects/" class="story-card story-card-3">
        <h3>Proof Through Shipping</h3>
        <p>Open-source systems, internal tools, and operational case studies that show how I design AI-enabled products in production.</p>
      </a>
    </div>
  </section>

  <!-- Three Stories -->
  <section class="container" style="margin-bottom: 3rem;">
    <h2>How I Help</h2>
    <div class="story-grid">
      <div class="story-card story-card-1">
        <h3>Workflow Discovery</h3>
        <p>Map the work your team repeats, score what is worth automating, and turn vague AI ambition into a concrete plan.</p>
      </div>
      <div class="story-card story-card-2">
        <h3>Implementation Design</h3>
        <p>Design the tooling, prompts, handoffs, and safeguards needed to ship internal AI systems that people will actually use.</p>
      </div>
      <div class="story-card story-card-3">
        <h3>Operational Enablement</h3>
        <p>Turn successful experiments into repeatable operating practices with documentation, standing orders, and measurable outcomes.</p>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="container" style="margin-bottom: 3rem;">
    <div class="section-heading">
      <h2>Latest Articles</h2>
      <a href="/articles/">View all &rarr;</a>
    </div>
    {articles.map((article) => (
      <ArticleCard
        title={article.data.title}
        slug={article.id}
        date={article.data.date}
        description={article.data.description}
        story={article.data.story}
      />
    ))}
  </section>
</Base>
