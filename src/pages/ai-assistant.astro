---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Build Your Own AI Personal Assistant',
  description:
    'A free, practical mini-course for building an AI personal assistant with the current Claude Cowork plugin workflow.',
  url: 'https://builtwithjon.com/ai-assistant/',
  provider: {
    '@type': 'Person',
    name: 'Jonathan Malkin',
    url: 'https://builtwithjon.com',
  },
  isAccessibleForFree: true,
};

const outcomes = [
  {
    icon: 'lucide:sun',
    tone: 'blue',
    title: 'A useful morning brief',
    copy: 'Your schedule, priorities, waiting items, and drafts in one place.',
  },
  {
    icon: 'lucide:users',
    tone: 'sage',
    title: 'Meeting prep that knows the room',
    copy: 'The people, context, open loops, and questions worth asking before you walk in.',
  },
  {
    icon: 'lucide:mail-check',
    tone: 'orange',
    title: 'Replies drafted for review',
    copy: 'Your assistant prepares the work. You stay in control of every send.',
  },
];
---

<Base
  title="Build Your Own AI Personal Assistant"
  description="A free mini-course that walks you through the current Claude Cowork plugin setup. Build a daily brief, meeting prep, and drafted replies without code."
  schema={pageSchema}
>
  <section class="assistant-course-hero container-wide">
    <div class="assistant-course-copy">
      <p class="eyebrow">Free Claude Cowork mini-course</p>
      <h1>Build the AI assistant you will actually use.</h1>
      <p class="subtitle">
        Follow the current Cowork plugin setup one practical step at a time. No
        terminal and no pile of disconnected prompts. You finish with an assistant
        that helps run your real day.
      </p>
      <div class="assistant-course-actions">
        <a href="/ai-assistant/course/" class="hero-btn">Join the free mini-course</a>
        <span>One prep email, then seven short daily lessons.</span>
      </div>
    </div>

    <figure class="assistant-course-media">
      <div class="assistant-course-frame">
        <img
          src="/ai-assistant/cowork/sample-outputs/daily-brief-sample.png"
          width="2080"
          height="2176"
          alt="Example Daily Brief showing meetings, goals, to-dos, and waiting items."
          loading="eager"
          decoding="async"
        />
      </div>
      <figcaption>This is the destination: one working brief for your day.</figcaption>
    </figure>
  </section>

  <section class="container-wide assistant-course-outcomes" aria-labelledby="course-outcomes-heading">
    <div class="assistant-course-intro">
      <p class="eyebrow">What you build</p>
      <h2 id="course-outcomes-heading">Something useful by Day 1. Better by Day 7.</h2>
      <p>
        Each lesson ends with the assistant doing real work. The longer written
        walkthrough remains available as a reference inside the course.
      </p>
    </div>

    <div class="assistant-outcome-grid">
      {
        outcomes.map((outcome) => (
          <article>
            <span class={`assistant-outcome-icon ${outcome.tone}`}>
              <Icon name={outcome.icon} />
            </span>
            <h3>{outcome.title}</h3>
            <p>{outcome.copy}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="container assistant-course-final">
    <p class="eyebrow">Start here</p>
    <h2>Want to build your own assistant?</h2>
    <p>
      Sign up for the free mini-course. I will walk you through the Cowork plugin,
      the setup, and the exact workflows I use myself.
    </p>
    <a href="/ai-assistant/course/" class="hero-btn">Save my spot</a>
  </section>

  <style>
    .assistant-course-hero {
      display: grid;
      grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
      gap: clamp(2rem, 5vw, 4.5rem);
      align-items: center;
      padding-top: clamp(2.5rem, 6vw, 5.5rem);
      padding-bottom: clamp(3rem, 7vw, 6rem);
    }

    .assistant-course-copy h1 {
      max-width: 760px;
      margin: 0.45rem 0 1.15rem;
      font-size: clamp(2.55rem, 6vw, 5rem);
      line-height: 0.97;
      letter-spacing: -0.045em;
    }

    .assistant-course-copy .subtitle {
      max-width: 640px;
      margin: 0;
      color: var(--color-text-muted);
      font-size: clamp(1.05rem, 2vw, 1.22rem);
      line-height: 1.55;
    }

    .assistant-course-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.9rem 1rem;
      margin-top: 1.7rem;
    }

    .assistant-course-actions span {
      max-width: 15rem;
      color: var(--color-text-muted);
      font-size: 0.9rem;
      line-height: 1.4;
    }

    .assistant-course-media {
      margin: 0;
    }

    .assistant-course-frame {
      position: relative;
      padding: clamp(0.7rem, 2vw, 1.15rem);
      overflow: hidden;
      border: 1px solid var(--color-border);
      border-radius: 18px;
      background:
        radial-gradient(circle at 12% 8%, rgba(229, 133, 47, 0.24), transparent 34%),
        radial-gradient(circle at 88% 92%, rgba(59, 110, 143, 0.22), transparent 38%),
        var(--color-surface);
      box-shadow: var(--shadow-card);
      transform: rotate(1.25deg);
    }

    .assistant-course-frame img {
      display: block;
      width: 100%;
      max-height: 620px;
      object-fit: cover;
      object-position: top;
      border: 1px solid var(--color-border);
      border-radius: 10px;
      background: var(--color-surface);
    }

    .assistant-course-media figcaption {
      margin-top: 0.9rem;
      color: var(--color-text-muted);
      font-size: 0.84rem;
      text-align: center;
    }

    .assistant-course-outcomes {
      padding-top: clamp(2.5rem, 5vw, 4.5rem);
      padding-bottom: clamp(3rem, 6vw, 5rem);
      border-top: 1px solid var(--color-border);
    }

    .assistant-course-intro {
      max-width: 720px;
      margin-bottom: 1.5rem;
    }

    .assistant-course-intro h2,
    .assistant-course-final h2 {
      margin: 0.35rem 0 0.7rem;
      font-size: clamp(1.8rem, 4vw, 3rem);
      line-height: 1.08;
    }

    .assistant-course-intro p:last-child,
    .assistant-course-final p {
      color: var(--color-text-muted);
    }

    .assistant-outcome-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .assistant-outcome-grid article {
      padding: 1.4rem;
      border: 1px solid var(--color-border);
      border-radius: 12px;
      background: var(--color-surface);
      box-shadow: var(--shadow-soft);
    }

    .assistant-outcome-icon {
      display: grid;
      width: 2.45rem;
      height: 2.45rem;
      place-items: center;
      margin-bottom: 1rem;
      border-radius: 9px;
      color: white;
    }

    .assistant-outcome-icon :global(svg) {
      width: 1.25rem;
      height: 1.25rem;
    }

    .assistant-outcome-icon.blue { background: var(--color-jules-blue); }
    .assistant-outcome-icon.sage { background: var(--color-jules-sage); }
    .assistant-outcome-icon.orange { background: var(--color-jules-orange-dark); }

    .assistant-outcome-grid h3 {
      margin: 0 0 0.45rem;
      font-size: 1.08rem;
    }

    .assistant-outcome-grid p {
      margin: 0;
      color: var(--color-text-muted);
    }

    .assistant-course-final {
      margin-top: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: clamp(3.5rem, 8vw, 7rem);
      padding: clamp(1.6rem, 4vw, 3rem);
      border: 1px solid var(--color-border);
      border-left: 7px solid var(--color-jules-orange);
      border-radius: 14px;
      background: var(--color-surface);
      box-shadow: var(--shadow-card);
    }

    .assistant-course-final p {
      max-width: 620px;
      margin-bottom: 1.4rem;
    }

    @media (max-width: 800px) {
      .assistant-course-hero,
      .assistant-outcome-grid {
        grid-template-columns: 1fr;
      }

      .assistant-course-hero {
        padding-top: 2rem;
      }

      .assistant-course-media {
        max-width: 620px;
      }

      .assistant-course-frame {
        transform: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .assistant-course-frame { transform: none; }
    }
  </style>
</Base>
