---
const pathname = Astro.url.pathname;

const servicesActive = pathname.startsWith('/ai-assistant') || pathname.startsWith('/hidden-profit-review');
const methodActive = pathname.startsWith('/principles') || pathname.startsWith('/process');
const workActive = pathname === '/projects/' || pathname.startsWith('/articles');
---

<header class="site-header">
  <nav>
    <a href="/" class="site-name">Jonathan Malkin</a>
    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav-links">
      <svg class="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <svg class="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="nav-links" id="site-nav-links">
      <div class={`nav-group${servicesActive ? ' is-active' : ''}`}>
        <button type="button" class="nav-group-toggle" aria-expanded="false" aria-controls="nav-services">
          Services
          <svg class="nav-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 4.5 6 8l3.5-3.5"/></svg>
        </button>
        <div class="nav-submenu" id="nav-services" role="menu">
          <a role="menuitem" href="/ai-assistant/" aria-current={pathname.startsWith('/ai-assistant') ? 'page' : undefined}>AI Assistant</a>
          <a role="menuitem" href="/hidden-profit-review/" aria-current={pathname.startsWith('/hidden-profit-review') ? 'page' : undefined}>Hidden Profit</a>
        </div>
      </div>

      <a href="/use-cases/" aria-current={pathname.startsWith('/use-cases') ? 'page' : undefined}>Use Cases</a>

      <div class={`nav-group${methodActive ? ' is-active' : ''}`}>
        <button type="button" class="nav-group-toggle" aria-expanded="false" aria-controls="nav-method">
          Method
          <svg class="nav-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 4.5 6 8l3.5-3.5"/></svg>
        </button>
        <div class="nav-submenu" id="nav-method" role="menu">
          <a role="menuitem" href="/principles/" aria-current={pathname.startsWith('/principles') ? 'page' : undefined}>Principles</a>
          <a role="menuitem" href="/process/" aria-current={pathname.startsWith('/process') ? 'page' : undefined}>Process</a>
        </div>
      </div>

      <div class={`nav-group${workActive ? ' is-active' : ''}`}>
        <button type="button" class="nav-group-toggle" aria-expanded="false" aria-controls="nav-work">
          Work
          <svg class="nav-caret" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 4.5 6 8l3.5-3.5"/></svg>
        </button>
        <div class="nav-submenu" id="nav-work" role="menu">
          <a role="menuitem" href="/projects/" aria-current={pathname === '/projects/' ? 'page' : undefined}>Projects</a>
          <a role="menuitem" href="/articles/" aria-current={pathname.startsWith('/articles') ? 'page' : undefined}>Articles</a>
        </div>
      </div>

      <a href="/contact/" aria-current={pathname === '/contact/' ? 'page' : undefined}>Contact</a>
      <a class="nav-cta" href="/scorecard/" aria-current={pathname.startsWith('/scorecard') ? 'page' : undefined}>Scorecard</a>
    </div>
    <div class="header-social">
      <a href="https://github.com/jonathanmalkin" rel="me" aria-label="GitHub" title="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://x.com/builtwithjon" rel="me" aria-label="X" title="X">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://linkedin.com/in/jonathanmalkin" rel="me" aria-label="LinkedIn" title="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="mailto:jonathan@builtwithjon.com" aria-label="Email" title="Email">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/><path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/></svg>
      </a>
    </div>
  </nav>
</header>

<script>
  document.querySelector('.menu-toggle')?.addEventListener('click', function () {
    const expanded = this.getAttribute('aria-expanded') === 'true';
    const nextExpanded = !expanded;
    this.setAttribute('aria-expanded', String(nextExpanded));
    this.setAttribute('aria-label', nextExpanded ? 'Close menu' : 'Open menu');
    document.querySelector('.nav-links')?.classList.toggle('open');
  });

  const navToggles = Array.from(document.querySelectorAll('.nav-group-toggle'));

  function closeAllGroups(except) {
    navToggles.forEach((btn) => {
      if (btn !== except) btn.setAttribute('aria-expanded', 'false');
    });
  }

  navToggles.forEach((btn) => {
    btn.addEventListener('click', function (event) {
      event.stopPropagation();
      const open = this.getAttribute('aria-expanded') === 'true';
      closeAllGroups(this);
      this.setAttribute('aria-expanded', String(!open));
    });

    btn.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        this.setAttribute('aria-expanded', 'false');
        this.focus();
      }
    });
  });

  // Click outside closes any open group (desktop dropdowns).
  document.addEventListener('click', function (event) {
    if (!event.target.closest('.nav-group')) closeAllGroups(null);
  });
</script>
