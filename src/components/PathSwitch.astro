---
// Shared breadcrumb / path-switch nav for the four AI assistant funnel pages.
// Pass `current` to mark the active page; that item renders as a non-clickable
// current marker instead of a link.
interface Props {
  current: 'hub' | 'cowork' | 'claude-code' | 'workshop' | 'workshop-austin';
}

const { current } = Astro.props;

const items = [
  { key: 'hub', label: 'All paths', href: '/ai-assistant/' },
  { key: 'cowork', label: 'Cowork DIY', href: '/ai-assistant/cowork/' },
  { key: 'claude-code', label: 'Claude Code DIY', href: '/ai-assistant/claude-code/' },
  { key: 'workshop', label: 'Online Class', href: '/ai-assistant-workshop/' },
  { key: 'workshop-austin', label: 'In-Person Austin Class', href: '/ai-assistant-workshop-austin/' },
];
---

<nav class="path-switch" aria-label="AI assistant paths">
  {
    items.map((item) =>
      item.key === current ? (
        <span aria-current="page">{item.label}</span>
      ) : (
        <a href={item.href}>{item.label}</a>
      )
    )
  }
</nav>

<style>
  .path-switch {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    align-items: center;
    margin: 0.5rem 0 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .path-switch a {
    color: var(--color-text-muted);
    padding: 0.3rem 0;
  }

  .path-switch a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .path-switch span[aria-current] {
    color: var(--color-text);
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
  }
</style>
