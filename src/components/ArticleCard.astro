---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  slug: string;
  date: Date;
  description: string;
  story: number;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { title, slug, date, description, image, imageAlt = '' } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="article-card">
  {image && (
    <a class="article-card-media" href={`/articles/${slug}/`} aria-label={title}>
      <Image
        src={image}
        alt={imageAlt}
        widths={[320, 520, 720]}
        sizes="(min-width: 760px) 220px, 100vw"
        format="webp"
        loading="lazy"
      />
    </a>
  )}
  <h3><a href={`/articles/${slug}/`}>{title}</a></h3>
  <div class="meta">
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <p class="description">{description}</p>
</article>

<style>
  .article-card-media {
    display: block;
    margin: 0 0 0.85rem;
  }

  .article-card-media :global(img) {
    aspect-ratio: 3 / 2;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    display: block;
    object-fit: cover;
    width: 100%;
  }
</style>
