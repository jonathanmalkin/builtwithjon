---
const formEndpoint = 'https://formspree.io/f/xdapgpae';
---

<section class="email-capture" id="subscribe">
  <h2>Get AI systems notes by email.</h2>
  <form
    action={formEndpoint}
    method="post"
    class="email-form"
    data-email-capture
  >
    <input type="hidden" name="_subject" value="Newsletter interest" />
    <input type="hidden" name="inquiry_type" value="newsletter-interest" />
    <input type="hidden" name="source" value="email-capture" />
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      aria-label="Email address"
      class="email-input"
    />
    <button type="submit" class="email-submit">Get notes</button>
  </form>
  <p class="email-status" data-email-capture-status hidden role="status"></p>
  <p class="email-disclosure">
    Occasional write-ups on AI operations, Claude Code, and implementation lessons.
    <a href="/privacy"> Privacy policy</a>.
  </p>
</section>

<script>
  document.querySelectorAll('[data-email-capture]').forEach((form) => {
    const status = form.parentElement?.querySelector('[data-email-capture-status]');
    const button = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      if (status) {
        status.hidden = true;
        status.textContent = '';
        status.removeAttribute('data-state');
      }

      if (button) {
        button.disabled = true;
        button.textContent = 'Sending...';
      }

      try {
        const data = new FormData(form);
        data.set('source_url', window.location.href);

        const response = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) throw new Error('newsletter_interest_failed');

        form.reset();
        if (status) {
          status.textContent = 'Got it. I will add you to the list or follow up if anything needs confirmation.';
          status.setAttribute('data-state', 'success');
          status.hidden = false;
        }
      } catch (error) {
        if (status) {
          status.textContent = 'That did not go through. Email jonathan@builtwithjon.com and I will add you manually.';
          status.setAttribute('data-state', 'error');
          status.hidden = false;
        }
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = 'Get notes';
        }
      }
    });
  });
</script>
