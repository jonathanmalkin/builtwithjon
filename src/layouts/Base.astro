---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EmailCapture from '../components/EmailCapture.astro';
import SEOHead from '../components/SEOHead.astro';
import JsonLd from '../components/JsonLd.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  hideFooter?: boolean;
}

const {
  title,
  description,
  image,
  article,
  publishedTime,
  modifiedTime,
  schema,
  noindex,
  hideFooter = false,
} = Astro.props;

const pageTitle = title === 'Jonathan Malkin'
  ? title
  : `${title} | Jonathan Malkin`;

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Archivo:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Jonathan Malkin" href="/rss.xml" />
    <title>{pageTitle}</title>
    <SEOHead
      title={pageTitle}
      description={description}
      image={image}
      article={article}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
    />
    {schema && <JsonLd schema={schema} />}
    <!-- Cloudflare Web Analytics is injected at the edge through Automatic Setup. -->
  </head>
  <body>
    <script is:inline>
(function () {
  function track(name) {
    try {
      if (!navigator.sendBeacon) return;
      var body = new Blob([JSON.stringify({ e: name, p: location.pathname, r: document.referrer })], { type: 'application/json' });
      navigator.sendBeacon('/api/event', body);
    } catch (err) {}
  }
  window.bwjTrack = track;
  document.addEventListener('click', function (ev) {
    var el = ev.target && ev.target.closest ? ev.target.closest('[data-track]') : null;
    if (el) track(el.getAttribute('data-track'));
  });
  document.addEventListener('focusin', function (ev) {
    var form = ev.target && ev.target.closest ? ev.target.closest('form[data-track-form]') : null;
    if (form && !form.dataset.trackStarted) {
      form.dataset.trackStarted = '1';
      track(form.getAttribute('data-track-form') + ':start');
    }
  });
  document.addEventListener('submit', function (ev) {
    var form = ev.target && ev.target.closest ? ev.target.closest('form[data-track-form]') : null;
    if (form) track(form.getAttribute('data-track-form') + ':submit');
  });
})();
</script>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    {article && <EmailCapture />}
    {!hideFooter && <Footer />}
  </body>
</html>
