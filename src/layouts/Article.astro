---
import Base from './Base.astro';
import BusinessBridge from '../components/BusinessBridge.astro';
interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  story: number;
  tags: string[];
  platforms?: {
    reddit?: string;
    x?: string;
  };
  image?: string;
}

const { title, description, date, updated, story, tags, platforms, image } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updated?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const authorSchema = {
  '@type': 'Person',
  name: 'Jonathan Malkin',
  jobTitle: 'AI Workflow Consultant & Implementation Partner',
  url: 'https://builtwithjon.com/about/',
  worksFor: {
    '@type': 'Organization',
    name: 'Built with Jon',
    url: 'https://builtwithjon.com/',
  },
  sameAs: [
    'https://github.com/jonathanmalkin',
    'https://x.com/builtwithjon',
    'https://linkedin.com/in/jonathanmalkin',
  ],
};

const MAGNETS = {
  calculator: {
    kicker: 'Free tool',
    title: 'The Leak Calculator',
    href: '/tools/leak-calculator/',
    blurb: 'Turn the math in this article into your own number. Pick the leak, enter three or four figures you already know, and see the monthly and annual cost with the source behind every benchmark. Takes about a minute.',
    cta: 'Run your numbers',
  },
  swipe: {
    kicker: 'Free swipe file',
    title: 'The Follow-Up Swipe File',
    href: '/kits/follow-up-swipe-file/',
    blurb: 'The 20 copy-paste messages that fix this leak: first responses, the bid follow-up ladder, handoffs, and invoice nudges, each with its timing rule. Adapt them to how you actually talk and send them.',
    cta: 'Get the swipe file',
  },
  kit: {
    kicker: 'Free kit',
    title: 'The Invoice-Chase Kit',
    href: '/kits/invoice-chase-kit/',
    blurb: 'The reminder sequence (day 0, 7, 14, 30 with email and text variants), the 15-minute weekly aging review, and the change-order capture log. Reminders draft on a clock; a human sends every one.',
    cta: 'Get the kit',
  },
};

const MAGNET_FOR_SLUG: Record<string, keyof typeof MAGNETS> = {
  'invoice-chase-payroll-problem': 'kit',
  'change-order-revenue-never-invoiced': 'kit',
  'rent-chase-standing-meeting': 'kit',
  'quote-that-waited-until-friday': 'swipe',
  'inquiry-that-booked-your-competitor': 'swipe',
  'leads-go-cold-heads-down-creating': 'swipe',
  'five-minute-reply-window-listing': 'swipe',
  'leasing-inquiry-applied-somewhere-else': 'swipe',
  'new-patient-reached-voicemail': 'swipe',
  'same-day-engagement-letters': 'swipe',
  'quiet-churn-never-exit-interviewed': 'swipe',
  'slow-bid-follow-up-loses-jobs': 'swipe',
  'missed-call-math-home-services': 'swipe',
  'fourteen-hours-that-never-pour-concrete': 'calculator',
  'packaging-tax-one-person-brand': 'calculator',
  'forty-documents-in-flight': 'calculator',
  'where-deals-actually-fall-through': 'calculator',
  'same-five-tenant-problems-loop': 'calculator',
  'empty-chairs-no-show-math': 'calculator',
  'two-clinical-days-prior-auth': 'calculator',
  'non-billable-admin-audit': 'calculator',
};

const slug = Astro.url.pathname.split('/').filter(Boolean).pop() ?? '';
const magnet = MAGNET_FOR_SLUG[slug] ? MAGNETS[MAGNET_FOR_SLUG[slug]] : null;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: authorSchema,
  publisher: authorSchema,
  ...(image ? { image: new URL(image, 'https://builtwithjon.com').href } : {}),
};
---

<Base
  title={title}
  description={description}
  image={image}
  article={true}
  publishedTime={date.toISOString()}
  modifiedTime={(updated ?? date).toISOString()}
  schema={articleSchema}
>
  <article class="container">
    <header class="article-header">
      <h1>{title}</h1>
      <div class="meta">
        <time datetime={date.toISOString()}>Published {formattedDate}</time>
        {formattedUpdated && updated && updated.getTime() !== date.getTime() && (
          <span> &middot; Updated {formattedUpdated}</span>
        )}
      </div>
      <aside class="article-author" aria-label="Article author">
        <div class="article-author-mark" aria-hidden="true">JM</div>
        <div>
          <p class="article-author-name">By <a href="/about/" rel="author">Jonathan Malkin</a></p>
          <p class="article-author-bio">AI workflow consultant in Austin, TX. Jonathan runs every Hidden Profit Review personally and builds the operating loops he recommends.</p>
        </div>
      </aside>
    </header>
    <div class="article-content">
      <slot />
    </div>
    {magnet && (
      <aside class="article-magnet" aria-label="Free resource">
        <p class="article-magnet-kicker">{magnet.kicker}</p>
        <p><strong>{magnet.title}.</strong> {magnet.blurb}</p>
        <p><a href={magnet.href}>{magnet.cta} &rarr;</a></p>
      </aside>
    )}
    <footer class="article-footer">
      {platforms && (platforms.reddit || platforms.x) && (
        <div class="platforms">
          <span>Also on:</span>
          {platforms.reddit && <a href={platforms.reddit}>Reddit</a>}
          {platforms.x && <a href={platforms.x}>X</a>}
        </div>
      )}
      {tags.length > 0 && (
        <p style="margin-top: 0.75rem;">
          Tags: {tags.join(', ')}
        </p>
      )}
    </footer>
    <BusinessBridge story={story} />
  </article>
</Base>
